---
// BlogPostLayout.astro - Zine-style Article Detail Page Layout
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import avatarImage from '../assets/images/avatar.jpg';
import type { BlogTagSlug } from '../utils/blog-tags';
import {
  blogFeatureImageSizes,
  blogFeatureImageWidths,
  blogPostCategoryMeta,
  formatBlogDate,
  type BlogCategory,
} from '../utils/blog-presentation';
import { getBlogPosts, getRelatedPosts } from '../utils/blog';
import BlogCard from '../components/BlogCard.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: BlogCategory;
  difficulty?: string;
  readingTime?: string;
  author: string;
  heroImage?: ImageMetadata;
  tags?: readonly BlogTagSlug[];
  tableOfContents?: Array<{
    slug: string;
    text: string;
  }>;
}

const {
  title,
  description,
  pubDate,
  category,
  difficulty = "Básico",
  readingTime = "5 min",
  author,
  heroImage,
  tags = [],
  tableOfContents = [],
} = Astro.props;

const formattedDate = formatBlogDate(pubDate);
const meta = blogPostCategoryMeta[category];

// JSON-LD BlogPosting Schema for SEO and AI Search engines
import { buildSchemaGraph } from '../utils/schema';

const articleSchema = buildSchemaGraph({
  pageType: 'blogPost',
  url: Astro.url.href,
  title,
  description,
  publishDate: pubDate,
  authorName: author,
  featureImageUrl: heroImage?.src,
  category,
  tags,
});

const markdownAlternateHref = `/blog/${Astro.params.slug}.md`;
const isStartGuide = Astro.params.slug === 'vermi-en-departamento';

const allPosts = await getBlogPosts();
const currentPost = allPosts.find(p => p.id === Astro.params.slug);
const allRelated = currentPost ? getRelatedPosts(currentPost, allPosts, 5) : [];

// Split related posts: 2 for sidebar, up to 3 for bottom
let sidebarRelatedPosts = allRelated.slice(0, 2);
let bottomRelatedPosts = allRelated.slice(2, 5);

// Pad sidebar and bottom posts with latest posts if they are short of target counts
const maxSidebar = 2;
const maxBottom = 3;

if (sidebarRelatedPosts.length < maxSidebar) {
  const existingIds = new Set([
    ...(currentPost ? [currentPost.id] : []),
    ...sidebarRelatedPosts.map(p => p.id),
    ...bottomRelatedPosts.map(p => p.id)
  ]);
  const fallbacks = allPosts.filter(p => !existingIds.has(p.id));
  sidebarRelatedPosts = [
    ...sidebarRelatedPosts,
    ...fallbacks.slice(0, maxSidebar - sidebarRelatedPosts.length)
  ];
}

if (bottomRelatedPosts.length < maxBottom) {
  const existingIds = new Set([
    ...(currentPost ? [currentPost.id] : []),
    ...sidebarRelatedPosts.map(p => p.id),
    ...bottomRelatedPosts.map(p => p.id)
  ]);
  const fallbacks = allPosts.filter(p => !existingIds.has(p.id));
  bottomRelatedPosts = [
    ...bottomRelatedPosts,
    ...fallbacks.slice(0, maxBottom - bottomRelatedPosts.length)
  ];
}
---

<BaseLayout 
  title={title} 
  description={description} 
  ogImage={heroImage?.src} 
  schema={articleSchema}
  mainClass="blog-layout__main max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-stack-gap flex-grow w-full box-border"
  extraLinks={[{ rel: 'alternate', type: 'text/markdown', href: markdownAlternateHref }]}
  articleMeta={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: pubDate.toISOString(),
    author: author
  }}
>
  <!-- Main Grid -->
  <div class="blog-layout__grid grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 w-full">
    
    <!-- Article Content (Main Column) -->
    <article class="blog-layout__article lg:col-span-8 space-y-8">
      <!-- Header -->
      <header class="space-y-6">
        <div class="flex flex-wrap items-center gap-3 font-mono text-sm">
          <span class={`rounded-full px-3 py-1 font-bold ${meta.tagBg} ${meta.tagText}`}>
            {meta.label}
          </span>
          <span class="text-on-surface-variant">
            {formattedDate}
          </span>
        </div>
        
        <h1 class="blog-layout__title page-title text-on-background m-0 mb-6">
          {title}
        </h1>
        
        <div class="flex items-center gap-4 border-t-2 border-b-2 border-on-surface py-4 my-6">
          <div class="w-12 h-12 rounded-full border-2 border-on-surface overflow-hidden shrink-0">
            <Image src={avatarImage} alt={author} class="w-full h-full object-cover" width={48} height={48} />
          </div>
          <div>
            <p class="font-label-md text-label-md text-on-surface m-0">Por {author}</p>
            <p class="font-body-md text-body-md text-on-surface-variant m-0">{readingTime} de lectura • Dificultad: {difficulty}</p>
          </div>
          
          <div class="ml-auto flex gap-2">
            <button id="share-btn" class="w-11 h-11 bg-surface-container-low border-2 border-on-surface flex items-center justify-center hover:bg-primary-container hover:text-on-primary-container organic-brutalism cursor-pointer" aria-label="Compartir esta guía">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
            </button>
          </div>
        </div>
      </header>

      <!-- Hero Image -->
      <figure class="relative w-full aspect-video border-2 border-on-surface organic-brutalism shadow-hard-sm overflow-hidden rotate-[-1deg] bg-tertiary-fixed m-0">
        {heroImage ? (
          <Image
            src={heroImage}
            alt={title}
            class="w-full h-full object-cover"
            widths={[...blogFeatureImageWidths]}
            sizes={blogFeatureImageSizes}
            quality="mid"
            loading="eager"
            fetchpriority="high"
          />
        ) : (
          <div class="w-full h-full object-cover bg-tertiary-fixed flex items-center justify-center p-8 box-border">
            <span class="font-headline text-2xl md:text-3xl text-on-surface text-center uppercase tracking-tight">{title}</span>
          </div>
        )}
      </figure>

      <!-- Content Body -->
      <div class="prose merriweather-body quiet-card p-6 md:p-8 relative">
        <!-- Table of Contents for Mobile -->
        {tableOfContents.length > 0 && (
          <TableOfContents tableOfContents={tableOfContents} variant="mobile" />
        )}
        
        <slot />
      </div>

    </article>

    <!-- Sidebar (Secondary Column) -->
    <aside class="blog-layout__sidebar lg:col-span-4 space-y-8 mt-8 lg:mt-0">
      <!-- Table of Contents -->
      {tableOfContents.length > 0 && (
        <TableOfContents tableOfContents={tableOfContents} variant="desktop" />
      )}

      <div class="quiet-card quiet-card--tinted p-6">
        <h2 class="font-headline text-2xl font-extrabold mb-2 leading-tight">
          {isStartGuide ? 'Ya estás en la ruta inicial' : '¿Recién estás empezando?'}
        </h2>
        <p class="font-body mb-5 leading-relaxed text-on-surface-variant">
          {isStartGuide
            ? 'Cuando termines, explora las demás guías según la duda que quieras resolver.'
            : 'Sigue la ruta inicial para elegir tu compostera, preparar la cama y evitar los errores más comunes.'}
        </p>
        <a href={isStartGuide ? '/blog/' : '/blog/vermi-en-departamento/'} class="font-mono text-sm font-bold text-primary underline decoration-2 underline-offset-4">
          {isStartGuide ? 'Ver todas las guías →' : 'Ir a la guía para empezar →'}
        </a>
      </div>

      <!-- Related Posts -->
      <div class="quiet-card quiet-card--tinted p-6">
        <h2 class="font-headline text-xl font-extrabold mb-4 border-b border-on-surface/30 pb-3">También te puede servir</h2>
        <div class="space-y-4 flex flex-col gap-4">
          {sidebarRelatedPosts.map((post, idx) => {
            const isAlt = idx % 2 === 1;
            const shapeClass = isAlt ? "organic-brutalism-alt" : "organic-brutalism";
            const textAccent = isAlt ? "text-secondary" : "text-primary";
            const categoryLabel = blogPostCategoryMeta[post.data.category]?.label || post.data.category;
            
            return (
              <>
                {idx > 0 && <div class="h-px w-full border-t-2 border-dashed border-on-surface"></div>}
                <a class="block group no-underline" href={`/blog/${post.id}/`}>
                  <div class="flex gap-4 items-center">
                    {post.data.heroImage ? (
                      <div class={`w-16 h-16 border-2 border-on-surface shrink-0 ${shapeClass} overflow-hidden`}>
                        <Image 
                          src={post.data.heroImage} 
                          alt={post.data.title} 
                          class="w-full h-full object-cover" 
                          width={64} 
                          height={64} 
                          quality="low"
                        />
                      </div>
                    ) : (
                      <div class={`w-16 h-16 bg-surface-dim border-2 border-on-surface shrink-0 ${shapeClass} overflow-hidden flex items-center justify-center font-headline text-lg ${textAccent}`}>
                        {post.data.title.slice(0, 3).toUpperCase()}
                      </div>
                    )}
                    <div>
                      <h3 class="font-headline text-base font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-2 m-0 leading-tight">
                        {post.data.title}
                      </h3>
                      <span class="text-label-md font-mono text-on-surface-variant font-bold">{categoryLabel}</span>
                    </div>
                  </div>
                </a>
              </>
            );
          })}
        </div>
      </div>
    </aside>
  </div>

  {bottomRelatedPosts.length > 0 && (
    <section class="mt-16 pt-12 border-t-2 border-on-background w-full box-border">
      <h2 class="section-heading text-on-surface mb-8 m-0">Sigue aprendiendo</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {bottomRelatedPosts.map((post) => {
          return (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              pubDate={post.data.pubDate}
              category={post.data.category}
              difficulty={post.data.difficulty}
              readingTime={post.readingTime}
              tags={post.data.tags}
              heroImage={post.data.heroImage}
            />
          );
        })}
      </div>
    </section>
  )}

  <script>
    const shareBtn = document.getElementById('share-btn');

    // Share logic: native share if available, fallback to clipboard copy
    if (shareBtn) {
      shareBtn.addEventListener('click', async () => {
        const shareData = {
          title: document.title,
          text: document.querySelector('meta[name="description"]')?.getAttribute('content') || '',
          url: window.location.href
        };

        if (navigator.share) {
          try {
            await navigator.share(shareData);
          } catch {
            // Closing the native share sheet is a normal user action.
          }
        } else {
          // Fallback to copy clipboard
          try {
            await navigator.clipboard.writeText(window.location.href);
            
            // Visual feedback: briefly modify button background
            const originalBg = shareBtn.className;
            shareBtn.classList.add('bg-primary-container', 'text-on-primary-container');
            const originalTitle = shareBtn.getAttribute('aria-label');
            shareBtn.setAttribute('aria-label', '¡Copiado!');
            
            // Create a temporary floating bubble or toast for feedback
            const toast = document.createElement('div');
            toast.className = 'toast-enter fixed bottom-8 right-8 bg-on-surface text-background border-2 border-on-surface px-4 py-2 font-mono text-xs font-bold rounded-lg z-toast';
            toast.setAttribute('role', 'status');
            toast.setAttribute('aria-live', 'polite');
            toast.textContent = '🪱 ¡Enlace copiado al portapapeles!';
            document.body.appendChild(toast);
            
            setTimeout(() => {
              shareBtn.className = originalBg;
              shareBtn.setAttribute('aria-label', originalTitle || 'Compartir');
              toast.remove();
            }, 2500);
          } catch {
            shareBtn.setAttribute('aria-label', 'No se pudo copiar el enlace');
          }
        }
      });
    }

  </script>
</BaseLayout>
