---
// BlogPostLayout.astro - Zine-style Article Detail Page Layout
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import avatarImage from '../assets/images/avatar.jpg';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: 'Manual' | 'Alimentación' | 'Problemas' | 'Cosecha';
  difficulty?: string;
  readingTime?: string;
  author: string;
  heroImage?: string;
}

const { title, description, pubDate, category, difficulty = "Básico", readingTime = "5 min", author, heroImage } = Astro.props;

// Format Date
const formattedDate = pubDate.toLocaleDateString('es-CL', {
  day: 'numeric',
  month: 'short',
  year: 'numeric'
}).toUpperCase();

// Category styles mapping matching Stitch
const categoryMeta = {
  Manual: { tagBg: 'bg-tertiary-fixed', tagText: 'text-on-tertiary-fixed', label: 'GUÍA PRÁCTICA' },
  Alimentación: { tagBg: 'bg-secondary-fixed', tagText: 'text-on-secondary-fixed', label: 'ALIMENTACIÓN' },
  Problemas: { tagBg: 'bg-mustard', tagText: 'text-on-background', label: 'SOLUCIÓN DE PROBLEMAS' },
  Cosecha: { tagBg: 'bg-primary-fixed', tagText: 'text-on-background', label: 'COSECHA' }
};
const meta = categoryMeta[category] || categoryMeta.Manual;

// JSON-LD BlogPosting Schema for SEO and AI Search engines
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": author
  },
  "publisher": {
    "@type": "Organization",
    "name": "vermi.cl",
    "logo": {
      "@type": "ImageObject",
      "url": "https://vermi.cl/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.toString()
  }
};
---

<BaseLayout 
  title={title} 
  description={description} 
  ogImage={heroImage} 
  schema={articleSchema}
  mainClass="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-stack-gap flex-grow w-full box-border"
>
  <!-- Main Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter w-full">
    
    <!-- Article Content (Main Column) -->
    <article class="lg:col-span-8 space-y-8">
      <!-- Header -->
      <header class="space-y-6">
        <div class="flex flex-wrap gap-3">
          <span class={`sticker-badge font-label-md text-label-md px-3 py-1 rotate-[-1deg] ${meta.tagBg} ${meta.tagText}`}>
            {meta.label}
          </span>
          <span class="sticker-badge bg-secondary-fixed text-on-secondary-fixed font-label-md text-label-md px-3 py-1 rotate-[2deg]">
            {formattedDate}
          </span>
        </div>
        
        <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl text-on-background font-black leading-tight tracking-tighter uppercase m-0">
          {title}
        </h1>
        
        <div class="flex items-center gap-4 border-t-2 border-b-2 border-on-surface py-4">
          <div class="w-12 h-12 rounded-full border-2 border-on-surface overflow-hidden shadow-hard-sm shrink-0">
            <Image src={avatarImage} alt={author} class="w-full h-full object-cover" width={48} height={48} />
          </div>
          <div>
            <p class="font-label-md text-label-md text-on-surface m-0">Por {author}</p>
            <p class="font-body-md text-body-md text-on-surface-variant m-0">{readingTime} de lectura • Dificultad: {difficulty}</p>
          </div>
          
          <div class="ml-auto flex gap-2">
            <button id="share-btn" class="w-10 h-10 bg-surface-container-high border-2 border-on-surface flex items-center justify-center hover:scale-110 hover:bg-primary-container hover:text-on-primary-container transition-all shadow-hard-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] organic-brutalism cursor-pointer" aria-label="Compartir">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
            </button>
            <button id="like-btn" class="w-10 h-10 bg-surface-container-high border-2 border-on-surface flex items-center justify-center hover:scale-110 hover:bg-secondary-container hover:text-on-secondary-container transition-all shadow-hard-sm hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] organic-brutalism-alt cursor-pointer" aria-label="Me gusta">
              <svg id="like-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </button>
          </div>
        </div>
      </header>

      <!-- Hero Image -->
      <figure class="relative w-full aspect-video border-4 border-on-surface organic-brutalism shadow-hard overflow-hidden rotate-[-1deg] bg-tertiary-fixed m-0">
        {heroImage ? (
          <img src={heroImage} alt={title} class="w-full h-full object-cover" />
        ) : (
          <div class="w-full h-full object-cover bg-tertiary-fixed flex items-center justify-center p-8 box-border">
            <span class="font-headline text-2xl md:text-3xl text-on-surface text-center uppercase tracking-tight">{title}</span>
          </div>
        )}
      </figure>

      <!-- Content Body -->
      <div class="editorial-body merriweather-body bg-surface-container-lowest p-6 md:p-8 border-2 border-on-surface shadow-hard organic-brutalism-alt relative">
        <!-- Decorative tape sticker -->
        <div class="absolute -top-3 left-10 w-20 h-6 bg-secondary-fixed/80 border border-on-surface rotate-[-5deg]"></div>
        
        <!-- Table of Contents for Mobile -->
        <div class="lg:hidden bg-tertiary-fixed border-3 border-on-surface p-6 mb-8 shadow-hard organic-brutalism rotate-[1deg]">
          <h2 class="font-headline text-xl font-bold text-on-surface mb-4 flex items-center gap-2 border-b-2 border-on-surface pb-2 uppercase">
            <!-- Inline SVG for Table of Contents -->
            <svg class="text-primary" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            En esta guía
          </h2>
          <ul class="space-y-3 font-mono text-sm pl-0 list-none m-0">
            <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
              <a href="#intro" class="text-on-surface font-bold no-underline">Introducción</a>
            </li>
            <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
              <a href="#sec1" class="text-on-surface font-bold no-underline"><span class="text-primary">1.</span> Señales clave</a>
            </li>
            <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
              <a href="#sec2" class="text-on-surface font-bold no-underline"><span class="text-primary">2.</span> Métodos de acción</a>
            </li>
            <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
              <a href="#sec3" class="text-on-surface font-bold no-underline"><span class="text-primary">3.</span> Cuidado biorregional</a>
            </li>
          </ul>
        </div>
        
        <slot />
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap items-center justify-between gap-4 mt-8 pt-8 border-t-4 border-on-surface border-dashed">
        <div class="flex gap-2">
          <span class="px-3 py-1 bg-surface-container-high border-2 border-on-surface text-label-md font-label-md rotate-[2deg]">#{category.toLowerCase()}</span>
          <span class="px-3 py-1 bg-surface-container-high border-2 border-on-surface text-label-md font-label-md rotate-[-1deg]">#compostaje</span>
        </div>
      </div>
    </article>

    <!-- Sidebar (Secondary Column) -->
    <aside class="lg:col-span-4 space-y-8 mt-8 lg:mt-0">
      <!-- Table of Contents -->
      <div class="hidden lg:block bg-tertiary-fixed border-3 border-on-surface p-6 shadow-hard organic-brutalism rotate-[1deg]">
        <h2 class="font-headline-md text-headline-md text-on-tertiary-fixed mb-4 flex items-center gap-2 border-b-2 border-on-surface pb-2 uppercase">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
          En esta guía
        </h2>
        <ul class="space-y-3 font-mono text-sm pl-0 list-none m-0">
          <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
            <a href="#intro" class="text-on-surface font-bold no-underline">Introducción</a>
          </li>
          <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
            <a href="#sec1" class="text-on-surface font-bold no-underline"><span class="text-primary">1.</span> Señales clave</a>
          </li>
          <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
            <a href="#sec2" class="text-on-surface font-bold no-underline"><span class="text-primary">2.</span> Métodos de acción</a>
          </li>
          <li class="hover:text-primary transition-colors hover:translate-x-1 cursor-pointer flex gap-2">
            <a href="#sec3" class="text-on-surface font-bold no-underline"><span class="text-primary">3.</span> Cuidado biorregional</a>
          </li>
        </ul>
      </div>

      <!-- CTA Sticker -->
      <div class="bg-primary-container text-on-primary-container border-4 border-on-surface p-6 shadow-hard organic-brutalism-alt rotate-[-2deg] relative overflow-hidden group">
        <div class="absolute -right-10 -top-10 w-32 h-32 bg-secondary rounded-full opacity-20 group-hover:scale-150 transition-transform duration-500"></div>
        <h2 class="font-headline-lg-mobile text-headline-lg-mobile font-black mb-2 relative z-10 uppercase leading-none">¿Dudas con tu vermi?</h2>
        <p class="font-body-md text-body-md mb-6 relative z-10 leading-relaxed">Únete a nuestro canal de la comunidad para resolver problemas de humedad y plagas en tiempo real.</p>
        <div class="flex flex-col gap-2 mt-2">
          <a href="#unirse" class="block w-full bg-secondary text-white font-mono text-sm font-bold text-center py-3 border-2 border-on-surface shadow-hard-sm hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all active:scale-95 relative z-10 no-underline">Únete a la comunidad</a>
          <a href="/contacto" class="block w-full bg-surface-container text-[#002201] font-mono text-sm font-bold text-center py-3 border-2 border-on-surface shadow-hard-sm hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all active:scale-95 relative z-10 no-underline">Escríbenos</a>
        </div>
      </div>

      <!-- Related Posts -->
      <div class="bg-surface-container border-2 border-on-surface p-6 shadow-hard organic-brutalism rotate-[0.5deg]">
        <h2 class="font-headline-md text-headline-md mb-4 border-b-2 border-on-surface pb-2 uppercase">Te podría interesar</h2>
        <div class="space-y-4 flex flex-col gap-4">
          <a class="block group no-underline" href="/blog/que-alimentos-no-dar">
            <div class="flex gap-4 items-center">
              <div class="w-16 h-16 bg-surface-dim border-2 border-on-surface shrink-0 organic-brutalism overflow-hidden flex items-center justify-center font-headline text-lg text-primary">
                NO
              </div>
              <div>
                <h3 class="font-label-md text-label-md text-on-surface group-hover:text-primary transition-colors line-clamp-2 uppercase m-0 leading-tight">Qué alimentos NO dar a tus lombrices</h3>
                <span class="text-[10px] font-mono text-on-surface-variant font-bold">ALIMENTACIÓN</span>
              </div>
            </div>
          </a>
          <div class="h-px w-full border-t-2 border-dashed border-on-surface"></div>
          <a class="block group no-underline" href="/blog/vermi-en-departamento">
            <div class="flex gap-4 items-center">
              <div class="w-16 h-16 bg-surface-dim border-2 border-on-surface shrink-0 organic-brutalism-alt overflow-hidden flex items-center justify-center font-headline text-lg text-secondary">
                DEPA
              </div>
              <div>
                <h3 class="font-label-md text-label-md text-on-surface group-hover:text-primary transition-colors line-clamp-2 uppercase m-0 leading-tight">Vermi en departamento: cómo empezar</h3>
                <span class="text-[10px] font-mono text-on-surface-variant font-bold">MANUAL</span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </aside>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const shareBtn = document.getElementById('share-btn');
      const likeBtn = document.getElementById('like-btn');
      const likeIcon = document.getElementById('like-icon');

      // Get current post slug from pathname for local storage key
      const postSlug = window.location.pathname.replace(/^\/|\/$/g, '').replace(/\//g, '-');
      const likeStorageKey = `vermi-liked-${postSlug}`;

      // Share logic: native share if available, fallback to clipboard copy
      if (shareBtn) {
        shareBtn.addEventListener('click', async () => {
          const shareData = {
            title: document.title,
            text: document.querySelector('meta[name="description"]')?.getAttribute('content') || '',
            url: window.location.href
          };

          if (navigator.share && navigator.canShare && navigator.canShare(shareData)) {
            try {
              await navigator.share(shareData);
            } catch (err) {
              console.error('Error sharing:', err);
            }
          } else {
            // Fallback to copy clipboard
            try {
              await navigator.clipboard.writeText(window.location.href);
              
              // Visual feedback: briefly modify button background
              const originalBg = shareBtn.className;
              shareBtn.classList.add('bg-primary-container', 'text-on-primary-container');
              const originalTitle = shareBtn.getAttribute('aria-label');
              shareBtn.setAttribute('aria-label', '¡Copiado!');
              
              // Create a temporary floating bubble or toast for feedback
              const toast = document.createElement('div');
              toast.className = 'fixed bottom-8 right-8 bg-[#002201] text-[#ecffe2] border-2 border-[#002201] px-4 py-2 font-mono text-xs font-bold rounded-lg shadow-hard z-[100] animate-bounce';
              toast.textContent = '🐛 ¡Enlace copiado al portapapeles!';
              document.body.appendChild(toast);
              
              setTimeout(() => {
                shareBtn.className = originalBg;
                shareBtn.setAttribute('aria-label', originalTitle || 'Compartir');
                toast.remove();
              }, 2500);
            } catch (err) {
              console.error('Failed to copy link:', err);
            }
          }
        });
      }

      // Like logic: local storage state toggle
      if (likeBtn && likeIcon) {
        const isLiked = localStorage.getItem(likeStorageKey) === 'true';
        if (isLiked) {
          likeIcon.setAttribute('fill', '#E05353');
          likeIcon.setAttribute('stroke', '#E05353');
        }

        likeBtn.addEventListener('click', () => {
          const currentlyLiked = localStorage.getItem(likeStorageKey) === 'true';
          if (currentlyLiked) {
            localStorage.setItem(likeStorageKey, 'false');
            likeIcon.setAttribute('fill', 'none');
            likeIcon.setAttribute('stroke', 'currentColor');
          } else {
            localStorage.setItem(likeStorageKey, 'true');
            likeIcon.setAttribute('fill', '#E05353');
            likeIcon.setAttribute('stroke', '#E05353');
          }
        });
      }
    });
  </script>
</BaseLayout>
