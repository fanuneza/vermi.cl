---
// BaseLayout.astro - Core Layout Shell for vermi.cl
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import defaultOgImage from '../assets/images/hero.jpg';
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';
import '../styles/global.css';

interface ArticleMeta {
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: Record<string, any>;
  mainClass?: string;
  articleMeta?: ArticleMeta;
}

const { 
  title, 
  description, 
  ogImage = defaultOgImage.src, 
  schema,
  mainClass = "flex-grow flex flex-col items-center w-full px-margin-mobile md:px-margin-desktop py-stack-gap md:py-16 gap-16 md:gap-24",
  articleMeta
} = Astro.props;

// SEO Helper calculations
const siteUrl = 'https://vermi.cl';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const makeAbsoluteUrl = (urlPath: string) => {
  if (!urlPath) return '';
  if (urlPath.startsWith('http://') || urlPath.startsWith('https://')) return urlPath;
  return `${siteUrl}${urlPath.startsWith('/') ? '' : '/'}${urlPath}`;
};

const ogImageAbsolute = makeAbsoluteUrl(ogImage);
const isArticle = Astro.url.pathname.startsWith('/blog/') && Astro.url.pathname !== '/blog';
const ogType = isArticle ? 'article' : 'website';

const seoArticle = isArticle && articleMeta ? {
  publishedTime: articleMeta.publishedTime ? new Date(articleMeta.publishedTime) : undefined,
  modifiedTime: articleMeta.modifiedTime ? new Date(articleMeta.modifiedTime) : undefined,
  authors: articleMeta.author ? [`${siteUrl}/nosotros/`] : undefined,
  section: 'Lombricultura'
} : undefined;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <Seo
      title={title}
      titleTemplate="%s | vermi.cl"
      description={description}
      canonical={canonicalUrl}
      ogType={ogType}
      ogImage={ogImageAbsolute}
      ogImageAlt={title}
      ogImageWidth={1200}
      ogImageHeight={675}
      siteName="vermi.cl"
      locale="es_CL"
      twitter={{ card: 'summary_large_image' }}
      article={seoArticle}
      graph={schema}
      extraLinks={[
        { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
        { rel: 'alternate', type: 'application/rss+xml', href: '/feed.xml', title: 'vermi.cl RSS' },
        { rel: 'alternate', type: 'text/markdown', href: '/llms.txt', title: 'vermi.cl LLM Context' }
      ]}
    />

    <!-- Dynamic slot for page-specific preloads and metadata -->
    <slot name="head" />
  </head>
  <body class="bg-background text-on-background font-body-md min-h-screen flex flex-col relative overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container">
    <Header />
    
    <main class={mainClass}>
      <slot />
    </main>
    
    <Footer />
  </body>
</html>

