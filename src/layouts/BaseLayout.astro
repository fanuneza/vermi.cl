---
// BaseLayout.astro - Core Layout Shell for vermi.cl
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: Record<string, any>;
  mainClass?: string;
}

const { 
  title, 
  description, 
  ogImage = '/images/default-og.png', 
  schema,
  mainClass = "flex-grow flex flex-col items-center w-full px-margin-mobile md:px-margin-desktop py-stack-gap md:py-16 gap-16 md:gap-24"
} = Astro.props;

// Default JSON-LD WebSite Schema
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "vermi.cl",
  "url": Astro.site ? Astro.site.toString() : "https://vermi.cl",
  "description": description
};

const finalSchema = schema || defaultSchema;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{title} | vermi.cl</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph Metadata -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="vermi.cl" />
    
    <!-- Twitter Metadata -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts Preconnect and Asynchronous Load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      rel="preload" 
      as="style" 
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..900&family=Fira+Sans:wght@400;500;700&family=Space+Mono:wght@400;700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400&display=swap" 
    />
    <link 
      rel="stylesheet" 
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..900&family=Fira+Sans:wght@400;500;700&family=Space+Mono:wght@400;700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400&display=swap" 
      media="print" 
      onload="this.media='all'" 
    />
    <noscript>
      <link 
        rel="stylesheet" 
        href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..900&family=Fira+Sans:wght@400;500;700&family=Space+Mono:wght@400;700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400&display=swap" 
      />
    </noscript>

    <!-- Schema.org JSON-LD structured data block -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
  </head>
  <body class="bg-background text-on-background font-body-md min-h-screen flex flex-col relative overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container">
    <Header />
    
    <main class={mainClass}>
      <slot />
    </main>
    
    <Footer />
  </body>
</html>
