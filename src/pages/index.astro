---
// index.astro - vermi.cl Homepage
import BaseLayout from '../layouts/BaseLayout.astro';
import IsItCompostable from '../components/IsItCompostable.astro';
import BlogCardGrid from '../components/BlogCardGrid.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getLatestPosts } from '../utils/blog';
import { faCarrot, faBookOpen, faAppleWhole, faWrench } from '@fortawesome/free-solid-svg-icons';
import { Image, getImage } from 'astro:assets';
import heroImage from '../assets/images/hero.jpg';

// Retrieve latest 3 posts for the home feed
const sortedPosts = await getLatestPosts(3);

const carrotPaths = Array.isArray(faCarrot.icon[4]) ? faCarrot.icon[4] : [faCarrot.icon[4]];
const bookOpenPaths = Array.isArray(faBookOpen.icon[4]) ? faBookOpen.icon[4] : [faBookOpen.icon[4]];
const appleWholePaths = Array.isArray(faAppleWhole.icon[4]) ? faAppleWhole.icon[4] : [faAppleWhole.icon[4]];
const wrenchPaths = Array.isArray(faWrench.icon[4]) ? faWrench.icon[4] : [faWrench.icon[4]];

import { buildSchemaGraph } from '../utils/schema';
import { HOME_METADATA } from '../utils/site-metadata';

const homepageSchema = buildSchemaGraph({
  pageType: 'website',
  url: 'https://vermi.cl/',
  title: 'Inicio',
  description: HOME_METADATA.description,
});


// Optimize LCP hero image for responsive preloading
const optimizedHero = await getImage({
  src: heroImage,
  width: 600,
  height: 450,
  format: 'webp',
  widths: [320, 480, 600],
  quality: 'mid'
});

const heroSrcSet = optimizedHero.srcSet.values
  .map(item => `${item.url} ${item.descriptor}`)
  .join(', ');
---

<BaseLayout
  title={HOME_METADATA.title}
  description={HOME_METADATA.description}
  schema={homepageSchema}
  mainClass="flex-grow flex flex-col items-center w-full px-margin-mobile md:px-margin-desktop py-stack-gap md:py-16 box-border"
>
  <link 
    rel="preload" 
    as="image" 
    href={optimizedHero.src} 
    imagesrcset={heroSrcSet} 
    imagesizes="(max-width: 480px) 320px, (max-width: 1024px) 480px, 600px"
    fetchpriority="high" 
    slot="head"
  />
  <!-- Hero Section -->
  <section class="w-full max-w-7xl grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center relative z-10">
    <div class="lg:col-span-6 flex flex-col items-start gap-6 relative z-10">
      <p class="m-0 font-mono text-sm font-bold text-secondary">Guías de vermicompostaje para Chile</p>
      <h1 class="page-title text-on-surface m-0">
        Empieza tu vermicompostera con una guía clara
      </h1>
      
      <p class="page-lead m-0">
        Aprende desde cero, incluso si vives en departamento. Te acompañamos para elegir tu compostera, preparar la cama y cuidar tus lombrices sin malos olores.
      </p>
      
      <div class="flex flex-col sm:flex-row sm:flex-wrap gap-3 mt-2 w-full sm:w-auto">
        <a href="/blog/vermi-en-departamento/" class="btn-primary no-underline">
          Empieza con la guía paso a paso
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <a href="/blog/" class="btn-secondary no-underline">
          Ver todas las guías
        </a>
      </div>
    </div>
    
    <div class="lg:col-span-6 relative mt-2 lg:mt-0">
      <div class="relative w-full aspect-[16/10] lg:aspect-[4/3] z-10 max-h-[28rem]">
        <Image 
          class="w-full h-full object-cover organic-shape-1 border-4 border-on-surface hard-shadow bg-tertiary-fixed" 
          src={heroImage} 
          alt="Compostaje de lombrices californianas" 
          width={600} 
          height={450} 
          widths={[320, 480, 600]}
          sizes="(max-width: 480px) 320px, (max-width: 1024px) 480px, 600px"
          loading="eager" 
          fetchpriority="high" 
          quality="mid"
        />
        <!-- One signature sticker keeps the scrapbook voice without crowding the image. -->
        <div class="absolute -bottom-2 -right-2 bg-surface-dim p-4 border-2 border-on-surface organic-shape-2 shadow-hard-sm rotate-[15deg]">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox={`0 0 ${faCarrot.icon[0]} ${faCarrot.icon[1]}`} fill="currentColor" class="text-primary">
            {carrotPaths.map((d) => <path d={d} />)}
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Cards Grid -->
  <section class="w-full max-w-7xl relative z-10 flex flex-col gap-8 mt-16 md:mt-24">
    <div class="max-w-2xl space-y-3">
      <h2 class="section-heading text-on-surface m-0">Tu ruta para empezar</h2>
      <p class="page-lead m-0">Parte por lo esencial y vuelve cuando aparezca una duda. No necesitas aprenderlo todo de una vez.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Card 1 -->
          <CategoryCard
            href="/blog/?category=Manual"
            title="Manual de inicio"
            description="Elige una compostera para tu espacio, prepara una cama húmeda y recibe tus lombrices sin complicarte."
            badgeText="Primer paso"
            cardBgClass="bg-tertiary-fixed"
            textColorHoverClass="group-hover:text-primary"
          >
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox={`0 0 ${faBookOpen.icon[0]} ${faBookOpen.icon[1]}`} fill="currentColor" class="text-primary">
              {bookOpenPaths.map((d) => <path d={d} />)}
            </svg>
          </CategoryCard>

          <!-- Card 2 -->
          <CategoryCard
            href="/blog/?category=Alimentación"
            title="Alimentación"
            description="Aprende qué residuos de cocina pueden comer, cuánto darles y cuándo agregar material seco."
            badgeText="Uso diario"
            cardBgClass="bg-surface-container"
            textColorHoverClass="group-hover:text-secondary"
          >
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox={`0 0 ${faAppleWhole.icon[0]} ${faAppleWhole.icon[1]}`} fill="currentColor" class="text-secondary">
              {appleWholePaths.map((d) => <path d={d} />)}
            </svg>
          </CategoryCard>

          <!-- Card 3 -->
          <CategoryCard
            href="/blog/?category=Problemas"
            title="Solución de problemas"
            description="Corrige malos olores, exceso de humedad, mosquitas o fugas con instrucciones paso a paso."
            badgeText="Cuando lo necesites"
            cardBgClass="bg-inverse-primary"
            textColorHoverClass="group-hover:text-tertiary"
            extraClasses="lg:col-span-1 md:col-span-2"
          >
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox={`0 0 ${faWrench.icon[0]} ${faWrench.icon[1]}`} fill="currentColor" class="text-tertiary">
              {wrenchPaths.map((d) => <path d={d} />)}
            </svg>
          </CategoryCard>
        </div>
  </section>

  <!-- Latest Guides Section -->
  <section class="w-full max-w-7xl relative z-10 flex flex-col gap-8 mt-16 md:mt-24">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <h2 class="section-heading text-on-surface m-0">Guías nuevas para seguir aprendiendo</h2>
      <a href="/blog/" class="font-mono text-sm font-bold text-primary underline decoration-2 underline-offset-4">
        Ver todas las guías
      </a>
    </div>
    
    <BlogCardGrid posts={sortedPosts} />
  </section>

  <!-- The checker is a utility for readers who already have a compostera. -->
  <section class="w-full max-w-7xl mt-16 md:mt-24" aria-labelledby="food-checker-heading">
    <div class="mb-6 max-w-2xl space-y-3">
      <p class="m-0 font-mono text-sm font-bold text-secondary">Para consultar mientras avanzas</p>
      <h2 id="food-checker-heading" class="section-heading m-0 text-on-surface">¿Tus lombrices pueden comer esto?</h2>
      <p class="page-lead m-0">Busca un residuo de cocina y revisa cómo ofrecerlo. Si todavía no tienes una compostera, empieza por las guías de arriba.</p>
    </div>
    <IsItCompostable />
  </section>
</BaseLayout>
