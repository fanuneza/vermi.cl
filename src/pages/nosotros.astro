---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import teamImage from '../assets/images/lombrices.jpeg';
import { buildSchemaGraph } from '../utils/schema';

// The first-view photo is about 336px wide on a 400px viewport. A 360px
// variant avoids selecting the 480px source under Lighthouse's mobile profile.
const aboutImageWidths = [320, 360, 480, 640, 768, 960] as const;
const aboutImageSizes =
  "(max-width: 1024px) calc(100vw - 4rem), 36rem";

const aboutSchema = buildSchemaGraph({
  pageType: 'about',
  url: 'https://vermi.cl/nosotros',
  title: 'Sobre nosotros',
  description: 'Conoce la historia detrás de vermi.cl, un portal creado por Fabián Núñez para compartir conocimiento práctico sobre vermicompostaje doméstico en departamentos y hogares de Chile.',
});
---

<BaseLayout
  title="Sobre mí y el propósito de vermi.cl"
  description="Conoce la historia detrás de vermi.cl, un portal creado por Fabián Núñez para compartir conocimiento práctico sobre vermicompostaje doméstico en departamentos y hogares de Chile."
  schema={aboutSchema}
  mainClass="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-stack-gap md:py-16 flex-grow w-full box-border"
>

  <!-- Hero Section -->
  <section class="mb-12 md:mb-16 max-w-4xl">
    <h1 class="page-title text-primary mb-4 m-0">Sobre mí y el propósito de vermi.cl</h1>
    <p class="page-lead mt-4 mb-0">
      Aprender a compostar con lombrices californianas en un departamento urbano tiene sus propios desafíos. Este espacio existe para compartir soluciones prácticas, reales y con base científica para lograrlo en Chile.
    </p>
  </section>

  <!-- Main Content Area - Bento Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start w-full">
    <!-- Polaroid -->
    <div class="lg:col-span-7">
      <figure class="bg-surface-container-lowest p-5 pb-8 border-2 border-on-surface shadow-hard-sm organic-brutalism w-full max-w-[36rem] -rotate-1 m-0">
        <Image
          src={teamImage}
          alt="Fotografía detallada de lombrices californianas en compostaje activo"
          class="w-full h-auto object-cover border-2 border-on-surface rounded-sm"
          widths={[...aboutImageWidths]}
          sizes={aboutImageSizes}
          loading="eager"
          fetchpriority="high"
        />
        <div class="mt-6 text-center">
          <span class="font-label-md text-label-md text-on-surface tracking-widest uppercase">Lombrices rojas californianas (*Eisenia fetida*) activas</span>
        </div>
      </figure>
    </div>

    <!-- Side Scraps -->
    <div class="lg:col-span-5 flex flex-col gap-8">
      <!-- Story Scrap -->
      <div class="quiet-card bg-mustard p-6">
        <h2 class="font-headline text-2xl font-extrabold text-on-surface mb-3 flex items-center gap-2">
          🌱 El origen del proyecto
        </h2>
        <p class="font-body text-base text-on-surface-variant leading-relaxed m-0 mb-4">
          Este sitio fue iniciado por <a href="https://fnunez.cl/?utm_source=vermi.cl&utm_medium=referral&utm_campaign=about_page" target="_blank" rel="noopener noreferrer nofollow" class="underline hover:text-primary transition-colors"><strong>Fabián Núñez</strong><span class="sr-only"> (abre en una nueva pestaña)</span></a>, un entusiasta de la lombricultura que vive en un departamento en Santiago.
        </p>
        <p class="font-body text-base text-on-surface-variant leading-relaxed m-0">
          Encontrar información adaptada a las condiciones locales (como la baja humedad relativa del Valle Central o las altas temperaturas del verano santiaguino en un balcón expuesto) no era fácil. Tras experimentar, cometer errores y perfeccionar el manejo de su vermicompostera en un espacio reducido, Fabián decidió documentar el proceso con un enfoque claro: rigor científico, relevancia chilena y aplicación inmediata.
        </p>
      </div>

      <!-- Who is this for Scrap -->
      <div class="quiet-card bg-surface p-6">
        <h2 class="font-headline text-2xl font-extrabold text-primary mb-4">¿Para quién es este espacio?</h2>
        <ul class="space-y-4 list-none pl-0 m-0">
          <li class="flex items-start gap-3">
            <div class="mt-1 w-6 h-6 border-2 border-on-surface bg-secondary-container rounded-sm flex items-center justify-center shrink-0">
              <span class="font-mono text-sm font-bold text-on-surface">✓</span>
            </div>
            <div>
              <strong class="font-label-md text-label-md block mb-1">Para quienes empiezan</strong>
              <span class="text-sm text-on-surface-variant">Guías paso a paso para armar el primer sustrato, evitar fugas de lombrices y no cometer el error de sobrealimentar el sistema.</span>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="mt-1 w-6 h-6 border-2 border-on-surface bg-primary-fixed rounded-sm flex items-center justify-center shrink-0">
              <span class="font-mono text-sm font-bold text-on-surface">✓</span>
            </div>
            <div>
              <strong class="font-label-md text-label-md block mb-1">Para vermicompostadores activos</strong>
              <span class="text-sm text-on-surface-variant">Análisis detallados sobre la microbiota del suelo, control de plagas típicas (como las hormigas), el uso correcto de humus en maceteros y la preparación de té de humus.</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Principles Scrap -->
      <div class="quiet-card bg-background p-6">
        <h2 class="font-headline text-2xl font-extrabold text-on-surface mb-3">Nuestros valores educativos</h2>
        <p class="font-body text-base text-on-surface-variant leading-relaxed m-0 mb-3">
          No vendemos insumos ni lombrices. El único propósito de este sitio es ofrecer <strong>educación honesta y de confianza</strong>.
        </p>
        <p class="font-body text-base text-on-surface-variant leading-relaxed m-0">
          Toda la información se apoya en literatura científica revisada por pares y en publicaciones de extensión universitaria, traduciendo la biología del suelo a consejos cotidianos que resuelven problemas prácticos reales.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
