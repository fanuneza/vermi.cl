---
// index.astro - Guides archive page with category filtering
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

// Get URL parameters
const categoryFilter = Astro.url.searchParams.get('category');

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Filter by category if param is present
const filteredPosts = categoryFilter 
  ? sortedPosts.filter(post => post.data.category === categoryFilter)
  : sortedPosts;

const categories = ['Manual', 'Alimentación', 'Problemas', 'Cosecha'];

const archiveSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Guías de vermicompostaje",
  "description": "Explora nuestras guías clasificadas para principiantes, alimentación de lombrices, control de plagas y cosecha de humus."
};
---

<BaseLayout 
  title="Archivo de guías" 
  description="Explora nuestras guías y manuales educativos de vermicompostaje doméstico en Chile." 
  schema={archiveSchema}
  mainClass="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-stack-gap flex-grow w-full box-border"
>
  <section class="w-full relative z-10 flex flex-col items-start gap-6">
    <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl text-on-surface font-black leading-tight tracking-tighter uppercase m-0">
      Archivo de guías
    </h1>
    <p class="font-body text-lg text-on-surface-variant max-w-2xl leading-relaxed m-0">
      Aprende el funcionamiento biológico de tu compostera y neutraliza los problemas típicos del clima mediterráneo de Chile.
    </p>

    <!-- Category Filter Chips -->
    <div class="flex flex-col gap-3 mb-8 items-start w-full">
      <h2 class="font-mono text-xs font-bold text-on-surface uppercase tracking-wider m-0">[ Filtrar por categoría ]</h2>
      <div class="flex flex-wrap gap-3">
        <a 
          href="/blog" 
          class={`font-mono text-sm font-bold border-2 border-on-surface px-4 py-1.5 shadow-[2px_2px_0px_0px_#002201] transition-all hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#002201] rounded-full no-underline ${!categoryFilter ? 'bg-primary text-white translate-x-[2px] translate-y-[2px] shadow-none' : 'bg-white text-on-surface'}`}
        >
          Todos
        </a>
        {categories.map(cat => (
          <a 
            href={`/blog?category=${cat}`} 
            class={`font-mono text-sm font-bold border-2 border-on-surface px-4 py-1.5 shadow-[2px_2px_0px_0px_#002201] transition-all hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#002201] rounded-full no-underline ${categoryFilter === cat ? 'bg-primary text-white translate-x-[2px] translate-y-[2px] shadow-none' : 'bg-white text-on-surface'}`}
          >
            {cat}
          </a>
        ))}
      </div>
    </div>

    <!-- Articles Grid -->
    {filteredPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full">
        {filteredPosts.map((post, idx) => {
          const rotations = ["rotate-[-1.5deg]", "rotate-[1deg]", "rotate-[-0.5deg]", "rotate-[0.5deg]"];
          const rot = rotations[idx % rotations.length];
          return (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              pubDate={post.data.pubDate}
              category={post.data.category}
              difficulty={post.data.difficulty}
              readingTime={post.data.readingTime}
              rotation={rot}
            />
          );
        })}
      </div>
    ) : (
      <div class="text-center p-12 max-w-xl mx-auto border-4 border-on-surface shadow-hard bg-white organic-brutalism w-full box-border">
        <h3 class="font-headline text-2xl font-black text-on-surface uppercase mb-3">No se encontraron guías</h3>
        <p class="font-body text-base text-on-surface-variant mb-6">Pronto publicaremos más artículos sobre esta temática. Mientras tanto, explora las demás categorías.</p>
        <a href="/blog" class="bg-primary text-on-primary font-headline text-lg px-6 py-3 rounded-lg btn-brutal flex items-center justify-center gap-2 max-w-xs mx-auto no-underline">
          Ver todas las guías
        </a>
      </div>
    )}
  </section>
</BaseLayout>
