---
// index.astro - Guides archive page with category filtering
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getBlogPosts } from '../../utils/blog';

const sortedPosts = await getBlogPosts();

const categories = ['Manual', 'Alimentación', 'Problemas', 'Cosecha'];

import { buildSchemaGraph } from '../../utils/schema';

const archiveSchema = buildSchemaGraph({
  pageType: 'blogListing',
  url: 'https://vermi.cl/blog',
  title: 'Archivo de guías',
  description: 'Explora nuestras guías y manuales educativos de vermicompostaje doméstico en Chile.',
});

---

<BaseLayout 
  title="Archivo de guías de vermicompostaje" 
  description="Explora nuestras guías y manuales educativos de vermicompostaje doméstico en Chile." 
  schema={archiveSchema}
  mainClass="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-stack-gap flex-grow w-full box-border"
>
  <section class="w-full relative z-10 flex flex-col items-start gap-6">
    <h1 class="page-title text-on-surface m-0">
      Guías para cuidar tu vermicompostera
    </h1>
    <p class="page-lead m-0">
      Empieza desde cero o encuentra una solución concreta para alimentación, humedad, clima, cosecha y problemas comunes en Chile.
    </p>

    <a href="/blog/vermi-en-departamento/" class="quiet-card quiet-card-link quiet-card--tinted flex w-full max-w-3xl flex-col gap-2 p-5 no-underline sm:flex-row sm:items-center sm:justify-between">
      <span>
        <strong class="block font-headline text-xl text-on-surface">¿Es tu primera vez?</strong>
        <span class="font-body text-on-surface-variant">Parte con la guía completa para comenzar en casa o departamento.</span>
      </span>
      <span class="shrink-0 font-mono text-sm font-bold text-primary">Empezar aquí →</span>
    </a>

    <!-- Category Filter Chips -->
    <div class="flex flex-col gap-3 mb-8 items-start w-full">
      <h2 class="font-headline text-lg font-extrabold text-on-surface m-0">Filtra por categoría</h2>
      <div id="filter-container" class="flex flex-wrap gap-3">
        <a
          href="/blog/"
          class="min-h-11 flex items-center font-mono text-sm font-bold border-2 border-on-surface px-4 py-2.5 bg-primary text-white rounded-full no-underline"
        >
          Todos
        </a>
        {categories.map(cat => (
          <a
            href={`/blog/?category=${cat}`}
            class="min-h-11 flex items-center font-mono text-sm font-bold border-2 border-on-surface px-4 py-2.5 bg-white text-on-surface hover:bg-surface-container rounded-full no-underline"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full">
      {sortedPosts.map((post, idx) => (
        <div class="post-card-wrapper" data-category={post.data.category}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate}
            category={post.data.category}
            difficulty={post.data.difficulty}
            readingTime={post.readingTime}
            tags={post.data.tags}
            heroImage={post.data.heroImage}
            loading={idx === 0 ? "eager" : "lazy"}
            fetchpriority={idx === 0 ? "high" : "auto"}
          />
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="no-posts-message" style="display: none;" class="quiet-card text-center p-8 md:p-12 max-w-xl mx-auto w-full box-border">
      <h3 class="font-headline text-2xl font-extrabold text-on-surface mb-3">No se encontraron guías</h3>
      <p class="font-body text-base text-on-surface-variant mb-6">Pronto publicaremos más artículos sobre esta temática. Mientras tanto, explora las demás categorías.</p>
      <a href="/blog/" id="reset-filter-btn" class="btn-primary max-w-xs mx-auto no-underline">
        Ver todas las guías
      </a>
    </div>
  </section>

  <script>
    const filterContainer = document.getElementById('filter-container');
    const filterLinks = filterContainer ? filterContainer.querySelectorAll('a') : [];
    const postWrappers = document.querySelectorAll('.post-card-wrapper');
    const noPostsMessage = document.getElementById('no-posts-message');
    const resetBtn = document.getElementById('reset-filter-btn');

    function applyFilter(category: string | null) {
      let visibleCount = 0;
      
      postWrappers.forEach(wrapper => {
        const postCategory = wrapper.getAttribute('data-category');
        if (!category || postCategory === category) {
          (wrapper as HTMLElement).style.display = 'block';
          visibleCount++;
        } else {
          (wrapper as HTMLElement).style.display = 'none';
        }
      });

      // Show/hide empty state message
      if (noPostsMessage) {
        if (visibleCount === 0) {
          noPostsMessage.style.display = 'block';
        } else {
          noPostsMessage.style.display = 'none';
        }
      }

      // Update active styling of filter links
      filterLinks.forEach(link => {
        const href = link.getAttribute('href') || '';
        const linkCat = href.includes('category=') ? decodeURIComponent(href.split('category=')[1]) : null;
        
        if (linkCat === category) {
          link.className = 'min-h-11 flex items-center font-mono text-sm font-bold border-2 border-on-surface px-4 py-2.5 bg-primary text-white rounded-full no-underline';
        } else {
          link.className = 'min-h-11 flex items-center font-mono text-sm font-bold border-2 border-on-surface px-4 py-2.5 bg-white text-on-surface hover:bg-surface-container rounded-full no-underline';
        }
      });
    }

    // Read query parameter initially
    const urlParams = new URLSearchParams(window.location.search);
    const initialCategory = urlParams.get('category');
    applyFilter(initialCategory);

    // Intercept clicks on filter links to perform instant client-side filtering without full page reload!
    filterLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href') || '';
        const newCat = href.includes('category=') ? decodeURIComponent(href.split('category=')[1]) : null;
        
        // Update URL search params without page reload
        const newUrl = newCat ? `${window.location.pathname}?category=${encodeURIComponent(newCat)}` : window.location.pathname;
        window.history.pushState({ category: newCat }, '', newUrl);
        
        applyFilter(newCat);
      });
    });

    if (resetBtn) {
      resetBtn.addEventListener('click', (e) => {
        e.preventDefault();
        window.history.pushState({ category: null }, '', window.location.pathname);
        applyFilter(null);
      });
    }

    // Listen to history popstate (e.g. back button)
    window.addEventListener('popstate', () => {
      const currentParams = new URLSearchParams(window.location.search);
      applyFilter(currentParams.get('category'));
    });
  </script>
</BaseLayout>
