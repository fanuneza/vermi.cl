---
import BaseLayout from "../layouts/BaseLayout.astro";
import FuzzyRedirect from "@jdevalk/astro-seo-graph/FuzzyRedirect.astro";
import { buildSchemaGraph } from "../utils/schema";

const pageSchema = buildSchemaGraph({
  pageType: "page",
  url: "https://vermi.cl/404",
  title: "Página no encontrada",
  description:
    "La página que buscas no existe. Tal vez fue devorada por las lombrices.",
});
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe o se ha movido. Tal vez se la comieron las lombrices."
  schema={pageSchema}
  mainClass="max-w-xl mx-auto px-margin-mobile md:px-margin-desktop py-stack-gap md:py-24 flex-grow w-full box-border flex flex-col items-center justify-center text-center"
>
  <div class="quiet-card bg-warning-tint p-8 md:p-12 max-w-md w-full relative">
    <div class="text-7xl mb-6">🪱❌</div>
    <h1 class="font-headline text-4xl md:text-5xl font-extrabold text-secondary m-0 leading-tight">Página no encontrada</h1>
    <p class="font-body text-base text-on-surface-variant leading-relaxed mb-6">
      La ruta que buscas no existe. Tal vez fue devorada por las lombrices californianas o se compostó por completo.
    </p>

    <!-- FuzzyRedirect container -->
    <div class="bg-surface-container border-2 border-on-surface p-4 rounded-lg font-mono text-sm mb-6 organic-brutalism-alt">
      <FuzzyRedirect 
        sitemapUrl="/sitemap.xml" 
        suggestionText="¿Quisiste decir:" 
        threshold={0.5} 
        autoRedirectThreshold={0.8} 
      />
    </div>

    <a href="/blog/" class="btn-primary no-underline">
      Explorar las guías
    </a>
  </div>
</BaseLayout>

<style is:global>
  /* Customize the FuzzyRedirect output text and link styling */
  #fuzzy-redirect {
    color: var(--color-ink);
  }
  #fuzzy-redirect a {
    color: var(--color-primary);
    font-weight: bold;
    text-decoration: underline;
  }
  #fuzzy-redirect a:hover {
    text-decoration: none;
  }
</style>
