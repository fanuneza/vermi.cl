---
// Header.astro - Reusable Stitch-style Navigation Bar
const { pathname } = Astro.url;

const isHome = pathname === '/' || pathname === '/index.html';
const isBlog = pathname.startsWith('/blog');
const isNosotros = pathname.startsWith('/nosotros');
---
<nav class="bg-surface dark:bg-surface-container w-full sticky top-0 z-50 border-b-4 border-on-surface shadow-[6px_6px_0px_0px_#002201] flex justify-between items-center px-margin-mobile md:px-margin-desktop py-4 max-w-full">
  
  <!-- Left Side: Hamburger Trigger (Mobile Only) -->
  <button id="menu-trigger" aria-label="Abrir menú" class="md:hidden text-primary hover:scale-105 active:scale-95 transition-transform flex items-center justify-center p-2 cursor-pointer">
    <!-- Inline SVG for FontAwesome faBars -->
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 448 512" fill="currentColor">
      <path d="M0 96C0 78.3 14.3 64 32 64l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 128C14.3 128 0 113.7 0 96zM0 256c0-17.7 14.3-32 32-32l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 288c-17.7 0-32-14.3-32-32zM448 416c0 17.7-14.3 32-32 32L32 448c-17.7 0-32-14.3-32-32s14.3-32 32-32l384 0c17.7 0 32 14.3 32 32z"/>
    </svg>
  </button>

  <!-- Logo (Centered on mobile, left-aligned on desktop) -->
  <a href="/" class="logo-link no-underline absolute left-1/2 -translate-x-1/2 md:static md:translate-x-0">
    <div class="font-headline text-headline-md font-black text-primary border-2 border-on-surface px-2 py-1 rotate-[-2deg] bg-surface-container-low shadow-[4px_4px_0px_0px_#002201] transition-transform hover:rotate-0">
      vermi.cl
    </div>
  </a>

  <!-- Middle: Navigation Links (Desktop Only) -->
  <div class="hidden md:flex items-center gap-6">
    <a class={isHome ? "text-primary font-bold border-b-4 border-primary pb-0.5 hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95" : "text-on-surface-variant font-body hover:text-primary hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95"} href="/">Inicio</a>
    <a class={isBlog ? "text-primary font-bold border-b-4 border-primary pb-0.5 hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95" : "text-on-surface-variant font-body hover:text-primary hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95"} href="/blog">Guías</a>
    <a class={isNosotros ? "text-primary font-bold border-b-4 border-primary pb-0.5 hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95" : "text-on-surface-variant font-body hover:text-primary hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95"} href="/nosotros">Nosotros</a>
  </div>

  <!-- Right Side: Actions (Desktop and Mobile) -->
  <div class="flex items-center gap-4">
    <!-- Desktop Search Icon -->
    <a href="/blog" class="hidden md:flex text-primary hover:scale-110 transition-transform items-center justify-center" aria-label="Buscar">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    </a>
    
    <!-- Desktop Join Button -->
    <button id="join-trigger-desktop" class="hidden md:block bg-primary-container text-on-primary-container font-label-md text-label-md px-4 py-2 border-2 border-on-surface shadow-hard-sm hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all active:scale-95 organic-brutalism rotate-[1deg] cursor-pointer">
      Unirse
    </button>

    <!-- Mobile Join Button -->
    <button id="join-trigger-mobile" class="md:hidden text-primary font-headline-md font-bold hover:scale-105 active:scale-95 transition-transform cursor-pointer">
      Unirse
    </button>
  </div>
</nav>

<!-- Mobile Navigation Drawer Overlay -->
<div id="drawer-overlay" class="fixed inset-0 bg-[#002201]/50 z-[100] transition-opacity duration-300 opacity-0 pointer-events-none"></div>

<!-- Mobile Navigation Drawer (Aside) -->
<aside id="nav-drawer" class="fixed top-0 left-0 h-full w-[280px] max-w-full bg-[#ecffe2] z-[101] transform -translate-x-full transition-transform duration-300 ease-in-out border-r-4 border-on-surface shadow-[6px_6px_0px_0px_#002201] flex flex-col pointer-events-auto">
  <!-- Drawer Header -->
  <div class="p-5 flex justify-between items-start border-b-4 border-on-surface/20 border-dashed bg-surface-container">
    <div class="font-headline text-2xl font-black text-secondary rotate-[-3deg] border-2 border-on-surface bg-surface-container-highest px-3 py-1 shadow-hard-sm inline-block">
      vermi.cl
    </div>
    <button id="close-drawer" aria-label="Cerrar menú" class="text-on-surface hover:text-secondary transition-colors p-2 rotate-[5deg] hover:rotate-[15deg] bg-surface-container-low border-2 border-on-surface rounded-full shadow-hard-sm active:translate-y-[2px] active:translate-x-[2px] active:shadow-none cursor-pointer flex items-center justify-center">
      <!-- Inline SVG for FontAwesome faXmark -->
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 384 512" fill="currentColor">
        <path d="M376.6 84.5c11.3-13.6 9.5-33.8-4.1-45.1s-33.8-9.5-45.1 4.1L192 206 56.6 47.5c-11.3-13.6-31.5-15.4-45.1-4.1s-15.4 31.5-4.1 45.1L142.9 256 7.5 427.5c-11.3 13.6-9.5 33.8 4.1 45.1s33.8 9.5 45.1-4.1L192 306 327.4 464.5c11.3 13.6 31.5 15.4 45.1 4.1s15.4-31.5 4.1-45.1L241.1 256 376.6 84.5z"/>
      </svg>
    </button>
  </div>

  <!-- Drawer Links -->
  <nav class="flex-1 overflow-y-auto p-5 flex flex-col gap-4 font-headline text-lg font-bold">
    <a class="group relative block w-full no-underline" href="/">
      <div class="absolute inset-0 bg-primary-container border-2 border-on-surface rounded-lg shadow-hard-sm translate-x-1 translate-y-1 transition-transform group-hover:translate-x-2 group-hover:translate-y-2"></div>
      <div class="relative bg-[#bcf0ae] text-[#002201] border-2 border-on-surface px-4 py-3 rounded-lg flex items-center gap-3">
        <!-- Inline SVG for FontAwesome faHome -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 576 512" fill="currentColor"><path d="M575.8 255.5c0 18-15 32.1-34 32.1h-32v176c0 26.5-21.5 48-48 48H384c-13.3 0-24-10.7-24-24V368c0-17.7-14.3-32-32-32h-64c-17.7 0-32 14.3-32 32v119.9c0 13.3-10.7 24-24 24H112c-26.5 0-48-21.5-48-48V287.6H32c-19 0-34-14.1-34-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 1 22 8L565.8 231.5c7 7 10 15 10 24z"/></svg>
        Inicio
      </div>
    </a>
    
    <a class="group relative block w-full mt-2 no-underline text-on-surface" href="/blog?category=Manual">
      <div class="relative bg-transparent hover:bg-surface-container px-4 py-2 border-b-4 border-transparent hover:border-on-surface transition-all rounded-sm flex items-center gap-3">
        <!-- Inline SVG for FontAwesome faBookOpen -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 576 512" fill="currentColor" class="text-primary"><path d="M249.6 47.1C231.4 34.6 209.1 29.5 187.1 33L37.1 58C15.9 61.6 0 80 0 101.5V416c0 22.4 15.7 41.7 37.7 46.2l160.2 32.8c11.9 2.4 24.1 2.4 36 0l160.2-32.8c22-4.5 37.7-23.8 37.7-46.2V101.5c0-21.5-15.9-39.8-37.1-43.5L249.6 47.1zM96 160h64c8.8 0 16 7.2 16 16s-7.2 16-16 16H96c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16H96c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16H96c-8.8 0-16-7.2-16-16s7.2-16 16-16zm224-192h64c8.8 0 16 7.2 16 16s-7.2 16-16 16h-64c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16h-64c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16h-64c-8.8 0-16-7.2-16-16s7.2-16 16-16z"/></svg>
        Manual de inicio
      </div>
    </a>
    
    <a class="group relative block w-full mt-2 no-underline text-on-surface" href="/blog?category=Alimentación">
      <div class="relative bg-transparent hover:bg-surface-container px-4 py-2 border-b-4 border-transparent hover:border-on-surface transition-all rounded-sm flex items-center gap-3">
        <!-- Inline SVG for FontAwesome faAppleWhole -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 448 512" fill="currentColor" class="text-secondary"><path d="M224 112c-8.8 0-16-7.2-16-16V48c0-8.8 7.2-16 16-16s16 7.2 16 16v48c0 8.8-7.2 16-16 16zm-76-20.9C133.4 99.4 114.7 112 96 112c-35.3 0-64-28.7-64-64S60.7 0 96 0c26.9 0 50 16.7 59.4 40.5C158 48.7 160 58.1 160 68c0 8.8-7.2 16-16 16s-16-7.2-16-16c0-4.4-.8-8.6-2.3-12.5C121 44.9 109.1 32 96 32c-17.7 0-32 14.3-32 32s14.3 32 32 32c10.3 0 19.3-4.8 25-12.3c6.2-8.2 15.7-12.7 25.7-12.7c15.8 0 29 11.5 31.6 27.2c.4 2.5 .6 5 .6 7.6c0 17.7-14.3 32-32 32zM336 96c-17.7 0-32 14.3-32 32c0 4.4-.8 8.6-2.3 12.5C289 125.1 277.1 112 264 112c-17.7 0-32 14.3-32 32s14.3 32 32 32c10.3 0 19.3-4.8 25-12.3c6.2-8.2 15.7-12.7 25.7-12.7c15.8 0 29 11.5 31.6 27.2c.4 2.5 .6 5 .6 7.6c0 17.7-14.3 32-32 32c-35.3 0-64-28.7-64-64s28.7-64 64-64c26.9 0 50 16.7 59.4 40.5C398 128.7 400 138.1 400 148c0 8.8-7.2 16-16 16s-16-7.2-16-16c0-8.8-7.2-16-16-16z"/></svg>
        Alimentación
      </div>
    </a>
    
    <a class="group relative block w-full mt-2 no-underline text-on-surface" href="/blog?category=Problemas">
      <div class="relative bg-transparent hover:bg-surface-container px-4 py-2 border-b-4 border-transparent hover:border-on-surface transition-all rounded-sm flex items-center gap-3">
        <!-- Inline SVG for FontAwesome faSkullCrossbones -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 448 512" fill="currentColor" class="text-tertiary"><path d="M439.2 236.7c-9.4-9.4-24.6-9.4-33.9 0l-57 57c-12 12-31.5 12-43.5 0l-57-57c-9.4-9.4-24.6-9.4-33.9 0s-9.4 24.6 0 33.9l57 57c12 12 12 31.5 0 43.5l-57 57c-9.4 9.4-9.4 24.6 0 33.9s24.6 9.4 33.9 0l57-57c12-12 31.5-12 43.5 0l57 57c9.4 9.4 24.6 9.4 33.9 0s9.4-24.6 0-33.9l-57-57c-12-12-12-31.5 0-43.5l57-57c9.4-9.4 9.4-24.6 0-33.9zM8.8 236.7c9.4-9.4 24.6-9.4 33.9 0l57 57c12 12 31.5 12 43.5 0l57-57c9.4-9.4 24.6-9.4 33.9 0s9.4 24.6 0 33.9l-57 57c-12 12-12 31.5 0 43.5l57 57c9.4 9.4 9.4 24.6 0 33.9s-24.6 9.4-33.9 0l-57-57c-12-12-31.5-12-43.5 0l-57 57c-9.4 9.4-24.6 9.4-33.9 0s-9.4-24.6 0-33.9l57-57c12-12 12-31.5 0-43.5l-57-57c-9.4-9.4-9.4-24.6 0-33.9zM224 256c53 0 96-43 96-96s-43-96-96-96s-96 43-96 96s43 96 96 96zm0-160c35.3 0 64 28.7 64 64s-28.7 64-64 64s-64-28.7-64-64s28.7-64 64-64z"/></svg>
        Solución de problemas
      </div>
    </a>
    
    <a class="group relative block w-full mt-2 no-underline text-on-surface" href="/blog?category=Cosecha">
      <div class="relative bg-transparent hover:bg-surface-container px-4 py-2 border-b-4 border-transparent hover:border-on-surface transition-all rounded-sm flex items-center gap-3">
        <!-- Inline SVG for FontAwesome faWorm -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 512 512" fill="currentColor" class="text-primary"><path d="M336 96c-17.7 0-32 14.3-32 32s14.3 32 32 32H448c17.7 0 32-14.3 32-32s-14.3-32-32-32H336zm0 96c-17.7 0-32 14.3-32 32s14.3 32 32 32H448c17.7 0 32-14.3 32-32s-14.3-32-32-32H336zM32 256H144c17.7 0 32-14.3 32-32s-14.3-32-32-32H32C14.3 192 0 206.3 0 224s14.3 32 32 32zm0 96H240c17.7 0 32-14.3 32-32s-14.3-32-32-32H32C14.3 288 0 302.3 0 320s14.3 32 32 32zm448 64c17.7 0 32-14.3 32-32s-14.3-32-32-32H32c-17.7 0-32 14.3-32 32s14.3 32 32 32H480z"/></svg>
        Cosecha de humus
      </div>
    </a>
  </nav>

  <!-- Drawer Footer -->
  <div class="p-5 flex justify-center items-center border-t-4 border-on-surface/20 border-dashed mt-auto bg-surface-container-low">
    <p class="font-mono text-xs text-on-surface-variant m-0 uppercase rotate-[2deg]">Hecho a mano 🐛</p>
  </div>
</aside>

<!-- Join Modal Overlay -->
<div id="join-modal" class="fixed inset-0 bg-[#002201]/70 z-[200] transition-opacity duration-300 opacity-0 pointer-events-none flex items-center justify-center p-4">
  <div class="bg-[#FFFBEA] border-4 border-on-surface p-8 max-w-md w-full shadow-hard relative transform rotate-[-0.5deg] organic-brutalism box-border">
    <!-- Decorative Tape -->
    <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 w-28 h-7 bg-secondary-container/90 border-2 border-on-surface -rotate-2 z-10"></div>
    
    <!-- Close Button -->
    <button id="close-modal" aria-label="Cerrar modal" class="absolute -top-3 -right-3 text-on-surface hover:text-secondary transition-colors p-2 rotate-[5deg] hover:rotate-[15deg] bg-surface-container border-2 border-on-surface rounded-full shadow-hard-sm active:translate-y-[2px] active:translate-x-[2px] active:shadow-none cursor-pointer flex items-center justify-center z-20">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 384 512" fill="currentColor">
        <path d="M376.6 84.5c11.3-13.6 9.5-33.8-4.1-45.1s-33.8-9.5-45.1 4.1L192 206 56.6 47.5c-11.3-13.6-31.5-15.4-45.1-4.1s-15.4 31.5-4.1 45.1L142.9 256 7.5 427.5c-11.3 13.6-9.5 33.8 4.1 45.1s33.8 9.5 45.1-4.1L192 306 327.4 464.5c11.3 13.6 31.5 15.4 45.1 4.1s15.4-31.5 4.1-45.1L241.1 256 376.6 84.5z"/>
      </svg>
    </button>
    
    <div class="flex flex-col gap-4 mt-2">
      <span class="inline-block bg-primary text-on-primary border-2 border-on-surface px-3 py-1 font-label-md text-label-md w-max rotate-[1deg] uppercase tracking-wider">Comunidad</span>
      <h2 class="font-headline text-2xl md:text-3xl font-black text-on-surface uppercase m-0 leading-none">Únete a la Colonia 🐛</h2>
      <p class="font-body text-sm text-on-surface-variant leading-relaxed m-0">
        Sé parte del mayor grupo de vermicompostadores de Chile. Recibe alertas biológicas estacionales y comparte tus experiencias con el humus.
      </p>
      
      <!-- Action buttons inside modal -->
      <div class="flex flex-col gap-3 mt-4 w-full">
        <!-- WhatsApp group invite placeholder -->
        <a 
          href="https://chat.whatsapp.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-[#25D366] text-white border-2 border-on-surface py-3 px-4 font-mono text-xs font-bold text-center shadow-hard-sm hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all rounded-sm no-underline flex items-center justify-center gap-2"
        >
          <span>Grupo de WhatsApp 💬</span>
        </a>
        
        <div class="h-px border-t-2 border-dashed border-on-surface my-2"></div>
        
        <!-- Newsletter signup -->
        <form class="space-y-4" onsubmit="event.preventDefault(); alert('¡Gracias por unirte! Revisa tu correo pronto.'); this.reset(); document.getElementById('join-modal').classList.add('pointer-events-none', 'opacity-0'); document.getElementById('join-modal').classList.remove('opacity-100');">
          <div class="flex flex-col gap-1.5">
            <label class="font-label-md text-[10px] uppercase text-[#154212] tracking-wider" for="modal-email">Newsletter Mensual</label>
            <input 
              type="email" 
              id="modal-email" 
              placeholder="tu-correo@lombriz.cl" 
              required 
              class="w-full bg-white border-2 border-on-surface px-3 py-2 text-sm font-body text-on-surface placeholder-on-surface/40 rounded-sm focus:ring-0 focus:outline-none"
            />
          </div>
          <button 
            type="submit" 
            class="w-full bg-secondary text-white border-2 border-on-surface py-2.5 px-4 font-mono text-xs font-bold shadow-hard-sm hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all rounded-sm cursor-pointer"
          >
            Suscribirse ✉
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('menu-trigger');
    const close = document.getElementById('close-drawer');
    const drawer = document.getElementById('nav-drawer');
    const overlay = document.getElementById('drawer-overlay');

    const modal = document.getElementById('join-modal');
    const closeModal = document.getElementById('close-modal');
    const desktopJoin = document.getElementById('join-trigger-desktop');
    const mobileJoin = document.getElementById('join-trigger-mobile');

    if (!trigger || !close || !drawer || !overlay) return;

    function openDrawer() {
      drawer.classList.remove('-translate-x-full');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.add('-translate-x-full');
      overlay.classList.remove('opacity-100', 'pointer-events-auto');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }

    function openModal() {
      closeDrawer(); // Close mobile drawer if open
      if (modal) {
        modal.classList.remove('pointer-events-none', 'opacity-0');
        modal.classList.add('opacity-100');
      }
    }

    function hideModal() {
      if (modal) {
        modal.classList.remove('opacity-100');
        modal.classList.add('pointer-events-none', 'opacity-0');
      }
    }

    trigger.addEventListener('click', openDrawer);
    close.addEventListener('click', closeDrawer);
    overlay.addEventListener('click', closeDrawer);

    if (desktopJoin) desktopJoin.addEventListener('click', openModal);
    if (mobileJoin) mobileJoin.addEventListener('click', openModal);
    if (closeModal) closeModal.addEventListener('click', hideModal);
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) hideModal();
      });
    }

    // Also support any global link pointing to #unirse
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (target && target.closest('[href="#unirse"]')) {
        e.preventDefault();
        openModal();
      }
    });
  });
</script>
