---
// Header.astro - Reusable Stitch-style Navigation Bar
import {
  type HiddenField,
  NEWSLETTER_FORM_CONFIG,
  isNewsletterFormConfigured,
} from "../utils/newsletter-form";

const { pathname } = Astro.url;

const isHome = pathname === "/" || pathname === "/index.html";
const isBlog = pathname.startsWith("/blog");
const isNosotros = pathname.startsWith("/nosotros");

const drawerLinks = [
  {
    href: "/",
    label: "Inicio",
    isActive: isHome,
    iconClass: "text-primary",
    iconPath: "M575.8 255.5c0 18-15 32.1-34 32.1h-32v176c0 26.5-21.5 48-48 48H384c-13.3 0-24-10.7-24-24V368c0-17.7-14.3-32-32-32h-64c-17.7 0-32 14.3-32 32v119.9c0 13.3-10.7 24-24 24H112c-26.5 0-48-21.5-48-48V287.6H32c-19 0-34-14.1-34-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 1 22 8L565.8 231.5c7 7 10 15 10 24z",
    viewBox: "0 0 576 512"
  },
  {
    href: "/blog/",
    label: "Guías",
    isActive: isBlog,
    iconClass: "text-primary",
    iconPath: "M249.6 47.1C231.4 34.6 209.1 29.5 187.1 33L37.1 58C15.9 61.6 0 80 0 101.5V416c0 22.4 15.7 41.7 37.7 46.2l160.2 32.8c11.9 2.4 24.1 2.4 36 0l160.2-32.8c22-4.5 37.7-23.8 37.7-46.2V101.5c0-21.5-15.9-39.8-37.1-43.5L249.6 47.1zM96 160h64c8.8 0 16 7.2 16 16s-7.2 16-16 16H96c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16H96c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16H96c-8.8 0-16-7.2-16-16s7.2-16 16-16zm224-192h64c8.8 0 16 7.2 16 16s-7.2 16-16 16h-64c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16h-64c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 96h64c8.8 0 16 7.2 16 16s-7.2 16-16 16h-64c-8.8 0-16-7.2-16-16s7.2-16 16-16z",
    viewBox: "0 0 576 512"
  },
  {
    href: "/nosotros/",
    label: "Nosotros",
    isActive: isNosotros,
    iconClass: "text-secondary",
    iconPath: "M144 0a80 80 0 1 1 0 160A80 80 0 1 1 144 0zM512 0a80 80 0 1 1 0 160A80 80 0 1 1 512 0zM0 298.7C0 239.8 47.8 192 106.7 192h74.7c58.9 0 106.7 47.8 106.7 106.7v53.3c0 17.7-14.3 32-32 32h-213.3c-17.7 0-32-14.3-32-32v-53.3zM640 298.7c0-58.9-47.8-106.7-106.7-106.7h-74.7c-58.9 0-106.7 47.8-106.7 106.7v53.3c0 17.7 14.3 32 32 32h213.3c17.7 0 32-14.3 32-32v-53.3zM416 96a64 64 0 1 1 -128 0 64 64 0 1 1 128 0zM192 480c0 17.7-14.3 32-32 32H64c-17.7 0-32-14.3-32-32V448c0-35.3 28.7-64 64-64h64c35.3 0 64 28.7 64 64v32zm384 0c0 17.7-14.3 32-32 32H480c-17.7 0-32-14.3-32-32V448c0-35.3 28.7-64 64-64h64c35.3 0 64 28.7 64 64v32z",
    viewBox: "0 0 640 512"
  }
];
---
<nav class="bg-surface dark:bg-surface-container w-full sticky top-0 z-50 border-b-4 border-on-surface shadow-[6px_6px_0px_0px_#002201] flex justify-between items-center px-margin-mobile md:px-margin-desktop py-4 max-w-full">
  <button id="menu-trigger" aria-label="Abrir menú" class="md:hidden text-primary hover:scale-105 active:scale-95 transition-transform flex items-center justify-center p-2 cursor-pointer">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 448 512" fill="currentColor">
      <path d="M0 96C0 78.3 14.3 64 32 64l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 128C14.3 128 0 113.7 0 96zM0 256c0-17.7 14.3-32 32-32l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 288c-17.7 0-32-14.3-32-32zM448 416c0 17.7-14.3 32-32 32L32 448c-17.7 0-32-14.3-32-32s14.3-32 32-32l384 0c17.7 0 32 14.3 32 32z"/>
    </svg>
  </button>

  <a href="/" class="logo-link no-underline absolute left-1/2 -translate-x-1/2 md:static md:translate-x-0">
    <div class="font-headline text-headline-md font-black text-secondary border-2 border-on-surface px-2 py-1 rotate-[-2deg] bg-surface-container-low shadow-[4px_4px_0px_0px_#002201] transition-transform hover:rotate-0">
      vermi.cl
    </div>
  </a>

  <div class="hidden md:flex items-center gap-6">
    <a class={isHome ? "text-primary font-bold border-b-4 border-primary pb-0.5 hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95" : "text-on-surface-variant font-body hover:text-primary hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95"} href="/">Inicio</a>
    <a class={isBlog ? "text-primary font-bold border-b-4 border-primary pb-0.5 hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95" : "text-on-surface-variant font-body hover:text-primary hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95"} href="/blog/">Guías</a>
    <a class={isNosotros ? "text-primary font-bold border-b-4 border-primary pb-0.5 hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95" : "text-on-surface-variant font-body hover:text-primary hover:translate-x-[2px] hover:translate-y-[2px] transition-all active:scale-95"} href="/nosotros/">Nosotros</a>
  </div>

  <div class="flex items-center gap-4">
    <button id="join-trigger-desktop" class="hidden md:block bg-primary-container text-on-primary-container font-label-md text-label-md px-4 py-2 border-2 border-on-surface shadow-hard-sm hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all active:scale-95 organic-brutalism rotate-[1deg] cursor-pointer">
      Unirse
    </button>

    <button id="join-trigger-mobile" class="md:hidden text-primary font-headline-md font-bold hover:scale-105 active:scale-95 transition-transform cursor-pointer">
      Unirse
    </button>
  </div>
</nav>

<div id="drawer-overlay" class="fixed inset-0 bg-[#002201]/50 z-[100] transition-opacity duration-300 opacity-0 pointer-events-none"></div>

<aside id="nav-drawer" class="fixed top-0 left-0 h-full w-[280px] max-w-full bg-[#ecffe2] z-[101] transform -translate-x-full transition-transform duration-300 ease-in-out border-r-4 border-on-surface shadow-[6px_6px_0px_0px_#002201] flex flex-col pointer-events-auto">
  <div class="p-5 flex justify-between items-start border-b-4 border-on-surface/20 border-dashed bg-surface-container">
    <div class="font-headline text-2xl font-black text-secondary rotate-[-3deg] border-2 border-on-surface bg-surface-container-highest px-3 py-1 shadow-hard-sm inline-block">
      vermi.cl
    </div>
    <button id="close-drawer" aria-label="Cerrar menú" class="text-on-surface hover:text-secondary transition-colors p-2 rotate-[5deg] hover:rotate-[15deg] bg-surface-container-low border-2 border-on-surface rounded-full shadow-hard-sm active:translate-y-[2px] active:translate-x-[2px] active:shadow-none cursor-pointer flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 384 512" fill="currentColor">
        <path d="M376.6 84.5c11.3-13.6 9.5-33.8-4.1-45.1s-33.8-9.5-45.1 4.1L192 206 56.6 47.5c-11.3-13.6-31.5-15.4-45.1-4.1s-15.4 31.5-4.1 45.1L142.9 256 7.5 427.5c-11.3 13.6-9.5 33.8 4.1 45.1s33.8 9.5 45.1-4.1L192 306 327.4 464.5c11.3 13.6 31.5 15.4 45.1 4.1s15.4-31.5 4.1-45.1L241.1 256 376.6 84.5z"/>
      </svg>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto p-5 flex flex-col gap-4 font-headline text-lg font-bold">
    {drawerLinks.map((link) => (
      <a class="group relative block w-full no-underline" href={link.href}>
        {link.isActive ? (
          <>
            <div class="absolute inset-0 bg-[#002201] border-2 border-on-surface rounded-lg shadow-hard-sm translate-x-1 translate-y-1"></div>
            <div class="relative bg-[#bcf0ae] text-[#002201] border-2 border-on-surface px-4 py-3 rounded-lg flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox={link.viewBox} fill="currentColor">
                <path d={link.iconPath}/>
              </svg>
              {link.label}
            </div>
          </>
        ) : (
          <div class="relative bg-transparent hover:bg-surface-container px-4 py-2 border-b-4 border-transparent hover:border-on-surface transition-all rounded-sm flex items-center gap-3 text-on-surface">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox={link.viewBox} fill="currentColor" class={link.iconClass}>
              <path d={link.iconPath}/>
            </svg>
            {link.label}
          </div>
        )}
      </a>
    ))}
  </nav>

  <div class="p-5 flex justify-center items-center border-t-4 border-on-surface/20 border-dashed mt-auto bg-surface-container-low">
    <p class="font-mono text-xs text-on-surface-variant m-0 uppercase rotate-[2deg]">Hecho a mano 🪱</p>
  </div>
</aside>

<div id="join-modal" class="fixed inset-0 bg-[#002201]/70 z-[200] transition-opacity duration-300 opacity-0 pointer-events-none flex items-center justify-center p-3 sm:p-4 md:p-6">
  <div class="relative w-full max-w-[42rem] overflow-visible px-1 sm:px-2">
    <div class="absolute -top-4 left-1/2 z-10 h-7 w-24 -translate-x-1/2 -rotate-2 border-2 border-on-surface bg-secondary-container/90 sm:w-28"></div>

    <button id="close-modal" aria-label="Cerrar modal" class="absolute -top-3 right-5 z-20 flex items-center justify-center rounded-full border-2 border-on-surface bg-surface-container p-2 text-on-surface shadow-hard-sm transition-colors rotate-[5deg] hover:rotate-[15deg] hover:text-secondary active:translate-x-[2px] active:translate-y-[2px] active:shadow-none sm:-right-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 384 512" fill="currentColor">
        <path d="M376.6 84.5c11.3-13.6 9.5-33.8-4.1-45.1s-33.8-9.5-45.1 4.1L192 206 56.6 47.5c-11.3-13.6-31.5-15.4-45.1-4.1s-15.4 31.5-4.1 45.1L142.9 256 7.5 427.5c-11.3 13.6-9.5 33.8 4.1 45.1s33.8 9.5 45.1-4.1L192 306 327.4 464.5c11.3 13.6 31.5 15.4 45.1 4.1s15.4-31.5 4.1-45.1L241.1 256 376.6 84.5z"/>
      </svg>
    </button>

    <div class="overflow-visible border-4 border-on-surface bg-[#FFFBEA] shadow-hard organic-brutalism">
      <div class="max-h-[calc(100vh-2rem)] overflow-y-auto overflow-x-hidden px-5 pb-5 pt-10 sm:max-h-[calc(100vh-3rem)] sm:px-7 sm:pb-7 sm:pt-12 md:px-8 md:pb-8">
        <div class="flex flex-col gap-4">
          <span class="inline-block w-max rotate-[1deg] border-2 border-on-surface bg-primary px-3 py-1 font-label-md text-label-md uppercase tracking-wider text-on-primary-container">Newsletter</span>
          <h2 class="m-0 font-headline text-2xl leading-none font-black text-on-surface uppercase md:text-3xl">Únete a la colonia 🪱</h2>
          <p class="m-0 font-body text-sm leading-relaxed text-on-surface-variant">
            Recibe alertas biológicas estacionales, novedades de vermi.cl y consejos prácticos para acompañar tu vermicompostera durante todo el año.
          </p>

          <div class="ml-subscribe-form ml-subscribe-form-43289892 mt-1 flex w-full flex-col gap-3">
            <div class="row-form">
              <form
                id="newsletter-form"
                action={NEWSLETTER_FORM_CONFIG.action || undefined}
                method="post"
                class="space-y-4"
                data-code=""
                toolname="suscribir_newsletter"
                tooldescription="Suscribe una dirección de correo electrónico al boletín informativo mensual de vermi.cl."
              >
                <div class="flex flex-col gap-1.5">
                  <label class="font-label-md text-[10px] uppercase tracking-wider text-[#154212]" for="modal-email">Newsletter mensual</label>
                  <input
                    type="email"
                    id="modal-email"
                    name={NEWSLETTER_FORM_CONFIG.emailFieldName}
                    placeholder="tu-correo@lombriz.cl"
                    required
                    toolparamdescription="Correo electrónico del suscriptor."
                    class="w-full rounded-sm border-2 border-on-surface bg-white px-3 py-2 text-sm font-body text-on-surface placeholder-on-surface/40 focus:outline-none focus:ring-0"
                  />
                </div>
                {NEWSLETTER_FORM_CONFIG.hiddenFields.map((field: HiddenField) => (
                  <input type="hidden" name={field.name} value={field.value} />
                ))}
                <button
                  type="submit"
                  disabled={!isNewsletterFormConfigured}
                  class="newsletter-submit w-full rounded-sm border-2 border-on-surface bg-secondary px-4 py-2.5 font-mono text-xs font-bold text-white shadow-hard-sm transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <span class="newsletter-submit-label">Suscribirse ✉</span>
                </button>
                {!isNewsletterFormConfigured && (
                  <p class="m-0 font-body text-xs text-on-surface-variant">
                    Falta pegar los datos públicos del formulario de MailerLite en <code>src/utils/newsletter-form.ts</code>.
                  </p>
                )}
              </form>
            </div>

            <div
              class="row-error hidden border-2 border-on-surface bg-[#FFF1E8] p-4 shadow-hard-sm organic-brutalism-alt"
              aria-live="polite"
            >
              <p class="m-0 font-label-md text-[10px] uppercase tracking-[0.22em] text-secondary">
                Algo falló
              </p>
              <p class="m-0 mt-2 font-body text-sm leading-relaxed text-on-surface-variant">
                No pudimos procesar tu suscripción ahora. Inténtalo de nuevo en unos minutos.
              </p>
            </div>

            <div
              class="row-success hidden border-2 border-on-surface bg-[#E8F8EE] p-4 shadow-hard-sm organic-brutalism-alt"
              aria-live="polite"
            >
              <p class="m-0 font-label-md text-[10px] uppercase tracking-[0.22em] text-primary">
                Confirmado
              </p>
              <h3 class="m-0 mt-2 font-headline text-xl font-black uppercase text-on-surface">
                Revisa tu correo
              </h3>
              <p class="m-0 mt-2 font-body text-sm leading-relaxed text-on-surface-variant">
                Te mandamos un mensaje para confirmar tu suscripción. Apenas la actives, recibirás nuestras alertas estacionales y novedades de vermi.cl sin salir de esta página.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const trigger = document.getElementById("menu-trigger");
  const close = document.getElementById("close-drawer");
  const drawer = document.getElementById("nav-drawer");
  const overlay = document.getElementById("drawer-overlay");

  const modal = document.getElementById("join-modal");
  const closeModal = document.getElementById("close-modal");
  const desktopJoin = document.getElementById("join-trigger-desktop");
  const mobileJoin = document.getElementById("join-trigger-mobile");
  const newsletterForm = document.getElementById(
    "newsletter-form",
  ) as HTMLFormElement | null;
  const newsletterSubmit = newsletterForm?.querySelector(
    ".newsletter-submit",
  ) as HTMLButtonElement | null;
  const newsletterSubmitLabel = newsletterSubmit?.querySelector(
    ".newsletter-submit-label",
  ) as HTMLSpanElement | null;
  const newsletterContainer = document.querySelector(
    ".ml-subscribe-form-43289892",
  ) as HTMLElement | null;
  const newsletterFormRow = newsletterContainer?.querySelector(
    ".row-form",
  ) as HTMLElement | null;
  const newsletterErrorRow = newsletterContainer?.querySelector(
    ".row-error",
  ) as HTMLElement | null;
  const newsletterSuccessRow = newsletterContainer?.querySelector(
    ".row-success",
  ) as HTMLElement | null;
  const mailerLiteWindow = window as Window & {
    ml_webform_success_43289892?: () => void;
  };

  const setNewsletterLoading = (isLoading: boolean) => {
    if (!newsletterSubmit || !newsletterSubmitLabel) return;
    newsletterSubmit.disabled = isLoading || !newsletterForm;
    newsletterSubmit.setAttribute("aria-busy", isLoading ? "true" : "false");
    newsletterSubmitLabel.textContent = isLoading
      ? "Enviando..."
      : "Suscribirse ✉";
  };

  const resetNewsletterState = () => {
    newsletterErrorRow?.classList.add("hidden");
    newsletterSuccessRow?.classList.add("hidden");
    newsletterFormRow?.classList.remove("hidden");
    setNewsletterLoading(false);
  };

  const showNewsletterSuccess = () => {
    newsletterErrorRow?.classList.add("hidden");
    newsletterFormRow?.classList.add("hidden");
    newsletterSuccessRow?.classList.remove("hidden");
    setNewsletterLoading(false);
    newsletterForm?.reset();
  };

  const showNewsletterError = () => {
    newsletterSuccessRow?.classList.add("hidden");
    newsletterErrorRow?.classList.remove("hidden");
    newsletterFormRow?.classList.remove("hidden");
    setNewsletterLoading(false);
  };

  mailerLiteWindow.ml_webform_success_43289892 = () => {
    showNewsletterSuccess();
  };

  newsletterForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!newsletterForm || !newsletterForm.action) {
      showNewsletterError();
      return;
    }

    setNewsletterLoading(true);
    newsletterErrorRow?.classList.add("hidden");

    try {
      const response = await fetch(newsletterForm.action, {
        method: "POST",
        body: new FormData(newsletterForm),
        headers: {
          Accept: "application/json",
        },
      });

      const responseText = await response.text();
      let payload: { success?: boolean } | null = null;

      try {
        payload = JSON.parse(responseText) as { success?: boolean };
      } catch {
        payload = null;
      }

      if (response.ok && payload?.success) {
        showNewsletterSuccess();
        return;
      }

      showNewsletterError();
    } catch {
      showNewsletterError();
    }
  });

  if (trigger && close && drawer && overlay) {
    const openDrawer = () => {
      drawer.classList.remove("-translate-x-full");
      overlay.classList.remove("opacity-0", "pointer-events-none");
      overlay.classList.add("opacity-100", "pointer-events-auto");
      document.body.style.overflow = "hidden";
    };

    const closeDrawer = () => {
      drawer.classList.add("-translate-x-full");
      overlay.classList.remove("opacity-100", "pointer-events-auto");
      overlay.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
    };

    const openModal = () => {
      closeDrawer();
      if (modal) {
        resetNewsletterState();
        modal.classList.remove("pointer-events-none", "opacity-0");
        modal.classList.add("opacity-100");
        document.body.style.overflow = "hidden";
      }
    };

    const hideModal = () => {
      if (modal) {
        modal.classList.remove("opacity-100");
        modal.classList.add("pointer-events-none", "opacity-0");
      }
      document.body.style.overflow = "";
      setNewsletterLoading(false);
    };

    trigger.addEventListener("click", openDrawer);
    close.addEventListener("click", closeDrawer);
    overlay.addEventListener("click", closeDrawer);

    if (desktopJoin) desktopJoin.addEventListener("click", openModal);
    if (mobileJoin) mobileJoin.addEventListener("click", openModal);
    if (closeModal) closeModal.addEventListener("click", hideModal);
    if (modal) {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) hideModal();
      });
    }

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement | null;
      if (target && target.closest('[href="#unirse"]')) {
        e.preventDefault();
        openModal();
      }
    });
  }
</script>
{isNewsletterFormConfigured && (
  <script
    is:inline
    defer
    src="https://groot.mailerlite.com/js/w/webforms.min.js"
  ></script>
)}
