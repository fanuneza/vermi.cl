---
// IsItCompostable.astro - The "¿Le puedo echar esto?" Interactive Widget
---
<div class="brutal-card search-widget-container">
  <div class="widget-header">
    <span class="font-mono-tag">[ MOTOR DE CONSULTA RÁPIDA V1.0 ]</span>
    <h2 class="widget-title">¿Puedo echarle esto a la vermi?</h2>
  </div>

  <div class="input-group">
    <label for="food-lookup-input" class="input-label">INGRESA EL ALIMENTO A EVALUAR:</label>
    <div class="search-input-wrapper">
      <input
        type="text"
        id="food-lookup-input"
        placeholder="Escribe el nombre del residuo (ej. palta, cítricos, cebolla)..."
        class="search-input"
        autocomplete="off"
      />
      <span class="search-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </span>
    </div>
  </div>

  <!-- Suggestion Tags -->
  <div class="suggestions-container">
    <span class="suggestion-label">Sugerencias:</span>
    <div class="suggestion-tags">
      <button class="btn-suggestion" data-food="plátano">Plátano 🍌</button>
      <button class="btn-suggestion" data-food="cítricos">Cítricos 🍊</button>
      <button class="btn-suggestion" data-food="cartón">Cartón 📦</button>
      <button class="btn-suggestion" data-food="café">Borra de Café ☕</button>
      <button class="btn-suggestion" data-food="cebolla">Cebolla 🧅</button>
      <button class="btn-suggestion" data-food="carne">Carne 🥩</button>
    </div>
  </div>

  <!-- Results Displays -->
  <div id="status-display-card" class="hidden result-card">
    <div class="result-header">
      <span class="font-mono-tag">[ ANÁLISIS BIOLÓGICO ]</span>
      <span id="badge-indicator" class="result-badge">SEGURO</span>
    </div>
    <h3 id="matched-food-name" class="result-food-name">Cáscara de Plátano</h3>
    
    <div class="chilean-context-wrapper">
      <p id="matched-chilean-context" class="result-chilean-context"></p>
    </div>
    
    <p id="matched-instructions" class="result-instructions"></p>
  </div>

  <div id="search-fallback-message" class="fallback-message">
    Escribe al menos dos letras para iniciar la consulta microbiológica del residuo.
  </div>
</div>

<style>
  .search-widget-container {
    max-w: 700px;
    margin: 2rem auto;
    background-color: var(--color-bg-warm);
    border-radius: 0;
    width: 100%;
  }

  .widget-header {
    border-bottom: 3px solid var(--color-ink);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .font-mono-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-gray-500);
    letter-spacing: 0.05em;
  }

  .widget-title {
    font-size: 1.75rem;
    margin-top: 0.25rem;
    color: var(--color-ink);
  }

  .input-group {
    margin-bottom: 1.25rem;
  }

  .input-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.5rem;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-input {
    width: 100%;
    border: 3px solid var(--color-ink);
    padding: 1rem 3rem 1rem 1rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    background-color: var(--color-white);
    color: var(--color-ink);
    box-shadow: 4px 4px 0px 0px var(--color-ink);
    transition: all 0.1s ease;
  }
  .search-input:focus {
    outline: none;
    background-color: #FFF2EE; /* Slightly warm orange focus */
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px 0px var(--color-ink);
  }

  .search-icon {
    position: absolute;
    right: 1.25rem;
    color: var(--color-ink);
    pointer-events: none;
    display: flex;
  }

  .suggestions-container {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .suggestion-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-gray-700);
  }

  .suggestion-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .btn-suggestion {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: bold;
    padding: 0.35rem 0.75rem;
    border: 2px solid var(--color-ink);
    background-color: var(--color-white);
    color: var(--color-ink);
    box-shadow: 2px 2px 0px 0px var(--color-ink);
    cursor: pointer;
    transition: all 0.1s ease;
  }
  .btn-suggestion:hover {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px 0px var(--color-ink);
    background-color: var(--color-gray-100);
  }
  .btn-suggestion:active {
    transform: translate(2px, 2px);
    box-shadow: 0px 0px 0px 0px var(--color-ink);
  }

  /* Result styling classes */
  .result-card {
    border: 3px solid var(--color-ink);
    padding: 1.5rem;
    box-shadow: 4px 4px 0px 0px var(--color-ink);
    margin-bottom: 1rem;
    transition: all 0.2s ease;
  }

  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .result-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 900;
    border: 2px solid var(--color-ink);
    padding: 0.2rem 0.6rem;
  }

  .result-food-name {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-ink);
  }

  .chilean-context-wrapper {
    border-left: 4px solid var(--color-ink);
    padding-left: 0.75rem;
    margin-bottom: 1rem;
    background-color: rgba(0, 0, 0, 0.03);
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
  }

  .result-chilean-context {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-gray-700);
  }

  .result-instructions {
    font-size: 0.95rem;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .fallback-message {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-gray-500);
    border: 2px dashed var(--color-gray-500);
    padding: 1.5rem;
    text-align: center;
    background-color: rgba(0, 0, 0, 0.01);
  }

  .hidden {
    display: none !important;
  }
</style>

<script>
  let searchIndex: any[] = [];
  let isIndexLoaded = false;

  const lookupInput = document.getElementById('food-lookup-input') as HTMLInputElement;
  const statusDisplay = document.getElementById('status-display-card') as HTMLDivElement;
  const fallbackMessage = document.getElementById('search-fallback-message') as HTMLDivElement;
  const badgeIndicator = document.getElementById('badge-indicator') as HTMLSpanElement;
  const matchedFoodName = document.getElementById('matched-food-name') as HTMLHeadingElement;
  const matchedChileanContext = document.getElementById('matched-chilean-context') as HTMLParagraphElement;
  const matchedInstructions = document.getElementById('matched-instructions') as HTMLParagraphElement;
  const suggestionButtons = document.querySelectorAll('.btn-suggestion');

  // Lazy-load the static JSON search index on first interaction
  const loadSearchIndex = async () => {
    if (isIndexLoaded) return;
    try {
      const response = await fetch('/api/alimentos.json');
      if (!response.ok) throw new Error('Error al descargar el índice de alimentos.');
      searchIndex = await response.json();
      isIndexLoaded = true;
    } catch (error) {
      console.error('Error de inicialización del buscador local:', error);
    }
  };

  const handleSearchEvent = () => {
    const rawQuery = lookupInput.value.toLowerCase().trim();
    
    if (rawQuery.length < 2) {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackMessage.textContent = 'Escribe al menos dos letras para iniciar la consulta microbiológica del residuo.';
      return;
    }

    if (!isIndexLoaded) return;

    // Fuzzy matching logic
    const filteredItem = searchIndex.find((item: any) =>
      item.name.toLowerCase().includes(rawQuery) ||
      item.category.toLowerCase().includes(rawQuery) ||
      (item.chileanContext && item.chileanContext.toLowerCase().includes(rawQuery))
    );

    if (filteredItem) {
      fallbackMessage.classList.add('hidden');
      statusDisplay.classList.remove('hidden');

      // Safe DOM manipulation to prevent XSS
      matchedFoodName.textContent = filteredItem.name;
      matchedChileanContext.textContent = `🇨🇱 Contexto Nacional: ${filteredItem.chileanContext || 'Información general.'}`;
      matchedInstructions.textContent = filteredItem.instructions;
      
      // Map statuses to zine style colors
      badgeIndicator.textContent = filteredItem.status.toUpperCase();
      badgeIndicator.className = 'result-badge';

      if (filteredItem.status === 'safe' || filteredItem.status === 'seguro') {
        statusDisplay.className = 'result-card';
        statusDisplay.style.backgroundColor = '#E8F8EE'; // light green
        badgeIndicator.style.backgroundColor = '#59C985'; // bright green
        badgeIndicator.style.color = '#111111';
        badgeIndicator.textContent = 'SEGURO';
      } else if (filteredItem.status === 'warning' || filteredItem.status === 'moderacion') {
        statusDisplay.className = 'result-card';
        statusDisplay.style.backgroundColor = '#FFFBEA'; // light yellow
        badgeIndicator.style.backgroundColor = '#F0C842'; // warning yellow
        badgeIndicator.style.color = '#111111';
        badgeIndicator.textContent = 'MODERACIÓN';
      } else if (filteredItem.status === 'danger' || filteredItem.status === 'peligro') {
        statusDisplay.className = 'result-card';
        statusDisplay.style.backgroundColor = '#FFF0F0'; // light red
        badgeIndicator.style.backgroundColor = '#E05353'; // danger red
        badgeIndicator.style.color = '#FFFFFF';
        badgeIndicator.textContent = 'PELIGRO';
      }
    } else {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackMessage.textContent = `No se registran datos sobre "${lookupInput.value}". Intenta con palabras clave como plátano, café, cítricos, cartón, plástico o carne.`;
    }
  };

  // Bind event listeners
  lookupInput.addEventListener('focus', loadSearchIndex);
  lookupInput.addEventListener('input', handleSearchEvent);

  // Suggestion buttons click handler
  suggestionButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      await loadSearchIndex();
      const food = (e.currentTarget as HTMLButtonElement).getAttribute('data-food') || '';
      lookupInput.value = food;
      handleSearchEvent();
    });
  });
</script>
