---
// IsItCompostable.astro - The "¿Las lombrices pueden comer esto?" Interactive Widget
---
<div id="buscador-alimentos" class="zine-block zine-block--food-search relative w-full max-w-4xl bg-surface-container-high border-2 border-on-background organic-shape-3 p-6 md:p-12 shadow-hard-sm my-8 z-10 box-border mx-auto">
  <div class="absolute -top-5 left-1/2 -translate-x-1/2 bg-surface text-on-background font-headline text-sm md:text-lg px-4 md:px-6 py-2 border-2 border-on-background shadow-hard-xs rotate-[-2deg] font-black w-[90%] md:w-auto text-center md:whitespace-nowrap uppercase">
    Buscador rápido
  </div>

  <div class="flex flex-col gap-6 mt-6">
    <div class="relative flex border-4 border-on-background rounded-full overflow-hidden bg-surface focus-within:ring-4 focus-within:ring-primary-container focus-within:border-primary transition-all">
      <!-- Inline SVG Search Icon to optimize Lighthouse scores -->
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input
        type="text"
        id="food-lookup-input"
        placeholder="Ej: cáscara de plátano, café, cítricos..."
        aria-label="Buscar si un alimento se puede compostar con lombrices"
        class="w-full border-none bg-transparent py-4 pl-14 pr-4 font-headline text-xl text-on-background placeholder:text-outline focus:ring-0 focus:outline-none"
        autocomplete="off"
      />
    </div>

    <!-- Suggestion Tags -->
    <div class="flex flex-wrap justify-center items-center gap-3 mt-4">
      <button class="min-h-11 bg-primary-container text-on-primary-container font-mono text-xs font-bold px-4 py-3 border-2 border-on-background shadow-hard-xs hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-hard-xxs transition-all rounded-sm rotate-1 btn-suggestion" data-food="plátano">Plátano 🍌</button>
      <button class="min-h-11 bg-mustard text-on-background font-mono text-xs font-bold px-4 py-3 border-2 border-on-background shadow-hard-xs hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-hard-xxs transition-all rounded-sm rotate-2 btn-suggestion" data-food="café">Borra de café ☕</button>
      <button class="min-h-11 bg-warning-badge text-on-background font-mono text-xs font-bold px-4 py-3 border-2 border-on-background shadow-hard-xs hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-hard-xxs transition-all rounded-sm rotate-[-2deg] btn-suggestion" data-food="cítricos">Cítricos 🍋</button>
      <button class="min-h-11 bg-danger-badge/10 text-on-background font-mono text-xs font-bold px-4 py-3 border-2 border-on-background shadow-hard-xs hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-hard-xxs transition-all rounded-sm rotate-1 btn-suggestion" data-food="cebolla">Cebolla 🧅</button>
      <button id="toggle-all-foods" type="button" aria-expanded="false" aria-controls="all-foods-panel" class="min-h-11 flex items-center font-mono text-xs font-bold px-4 py-3 border-2 border-dashed border-on-background/50 text-on-background/70 hover:text-on-background hover:border-on-background transition-colors rounded-sm">Ver más alimentos →</button>
    </div>

    <div class="grid transition-[grid-template-rows] duration-300 ease-out" style="grid-template-rows: 0fr;" id="all-foods-wrapper">
      <div class="min-h-0 overflow-y-auto overscroll-contain max-h-[50svh] md:max-h-none md:overflow-visible" role="region" aria-label="Lista ampliada de alimentos">
        <div id="all-foods-panel" class="flex flex-wrap justify-center items-center gap-3 pt-4"></div>
        <div class="flex justify-center mt-4">
          <button id="collapse-all-foods" type="button" class="min-h-11 flex items-center font-mono text-xs font-bold px-4 py-3 border-2 border-dashed border-on-background/50 text-on-background/70 hover:text-on-background hover:border-on-background transition-colors rounded-sm">Ver menos ↑</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Results Displays -->
  <div id="status-display-card" class="hidden w-full border-4 border-on-background p-6 organic-brutalism bg-success-tint mt-6 box-border" aria-live="polite" aria-atomic="true">
    <div class="flex justify-between items-center border-b-2 border-on-background pb-3 mb-4">
      <span class="font-mono text-xs font-bold text-on-background tracking-wider">[ VEREDICTO DE TUS LOMBRICES ]</span>
      <span id="badge-indicator" class="font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-safe-badge text-on-background">SEGURO</span>
    </div>
    <h3 id="matched-food-name" class="font-headline text-2xl md:text-3xl font-black text-on-background mb-3 uppercase">Cáscara de plátano</h3>

    <div id="matched-nutrition-container" class="border-2 border-on-background px-3 py-2 mb-4 bg-surface-container-lowest/60 organic-brutalism-alt">
      <p id="matched-nutrition" class="font-mono text-sm text-on-background m-0"></p>
    </div>

    <p id="matched-instructions" class="font-body text-base text-on-background leading-relaxed m-0"></p>
  </div>

  <div id="search-fallback-message" class="font-mono text-sm text-ink border-2 border-dashed border-on-background p-5 text-center bg-white/20 mt-6 rounded-lg box-border" aria-live="polite" aria-atomic="true">
    <p id="search-fallback-copy" class="m-0">Escribe al menos dos letras y te contamos qué opinan tus lombrices 🪱.</p>
    <button id="retry-food-search" type="button" class="btn-secondary hidden mx-auto mt-4 bg-white">Reintentar</button>
  </div>
</div>

<script>
  interface FoodEntry {
    name: string;
    category: string;
    status: "safe" | "warning" | "danger" | "seguro" | "moderacion" | "peligro";
    instructions: string;
    nutrition?: string;
    keywords?: string;
  }

  let searchIndex: FoodEntry[] = [];
  let isIndexLoaded = false;
  let indexPromise: Promise<void> | null = null;

  const lookupInput = document.getElementById('food-lookup-input') as HTMLInputElement;
  const statusDisplay = document.getElementById('status-display-card') as HTMLDivElement;
  const fallbackMessage = document.getElementById('search-fallback-message') as HTMLDivElement;
  const fallbackCopy = document.getElementById('search-fallback-copy') as HTMLParagraphElement;
  const retryButton = document.getElementById('retry-food-search') as HTMLButtonElement;
  const badgeIndicator = document.getElementById('badge-indicator') as HTMLSpanElement;
  const matchedFoodName = document.getElementById('matched-food-name') as HTMLHeadingElement;
  const matchedNutritionContainer = document.getElementById('matched-nutrition-container') as HTMLDivElement;
  const matchedNutrition = document.getElementById('matched-nutrition') as HTMLParagraphElement;
  const matchedInstructions = document.getElementById('matched-instructions') as HTMLParagraphElement;
  const suggestionButtons = document.querySelectorAll('.btn-suggestion');
  const toggleAllFoodsBtn = document.getElementById('toggle-all-foods') as HTMLButtonElement | null;
  const collapseAllFoodsBtn = document.getElementById('collapse-all-foods') as HTMLButtonElement | null;
  const allFoodsWrapper = document.getElementById('all-foods-wrapper') as HTMLDivElement | null;
  const allFoodsPanel = document.getElementById('all-foods-panel') as HTMLDivElement | null;
  let allFoodsRendered = false;

  // Food-specific emoji, keyed by normalized name. Falls back to a status-based emoji.
  const FOOD_EMOJI: Record<string, string> = {
    'aji': '🌶️',
    'ajo': '🧄',
    'almidones y harinas': '🌾',
    'hierbas aromaticas': '🌿',
    'aserrin': '🪵',
    'berenjena': '🍆',
    'betarraga': '🟣',
    'borra de cafe': '☕',
    'carne y huesos': '🍖',
    'carton': '📦',
    'cebolla': '🧅',
    'citricos': '🍋',
    'comida cocinada y aliñada': '🍲',
    'cuescos y carozos': '🥭',
    'fibra de coco': '🥥',
    'frutas dulces de verano': '🍑',
    'frutas tropicales y andinas': '🍍',
    'hojas secas': '🍂',
    'hojas verdes': '🥬',
    'hierbas culinarias': '🌿',
    'huevo y cascaras': '🥚',
    'lacteos y quesos': '🧀',
    'legumbres': '🫘',
    'manzana': '🍎',
    'palta (cascaras)': '🥑',
    'pan': '🍞',
    'papa (cascaras)': '🥔',
    'papel': '📄',
    'pera': '🍐',
    'pimenton': '🫑',
    'platano': '🍌',
    'ramas': '🌳',
    'tomate': '🍅',
    'uva': '🍇',
    'vegetales y verduras de hoja': '🥦',
    'zanahoria': '🥕',
  };

  const STATUS_EMOJI: Record<string, string> = { safe: '🌱', warning: '⚠️', danger: '🚫' };
  const STATUS_CLASS: Record<string, string> = {
    safe: 'bg-safe-badge/20',
    warning: 'bg-warning-badge',
    danger: 'bg-danger-badge/10',
  };

  const normalizeStatus = (status: string) => {
    if (status === 'safe' || status === 'seguro') return 'safe';
    if (status === 'warning' || status === 'moderacion') return 'warning';
    return 'danger';
  };

  const getFoodEmoji = (item: FoodEntry) =>
    FOOD_EMOJI[normalizeString(item.name)] ?? STATUS_EMOJI[normalizeStatus(item.status)];

  const collapseAllFoods = () => {
    if (!toggleAllFoodsBtn || !allFoodsWrapper) return;
    allFoodsWrapper.style.gridTemplateRows = '0fr';
    toggleAllFoodsBtn.setAttribute('aria-expanded', 'false');
    toggleAllFoodsBtn.classList.remove('hidden');
  };

  const scrollToResult = () => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    statusDisplay.scrollIntoView({
      behavior: prefersReducedMotion ? 'auto' : 'smooth',
      block: 'start',
    });
  };

  const revealResultAfterFoodPick = () => {
    if (!allFoodsWrapper || allFoodsWrapper.style.gridTemplateRows !== '1fr') {
      requestAnimationFrame(scrollToResult);
      return;
    }

    let hasScrolled = false;
    const scrollOnce = () => {
      if (hasScrolled) return;
      hasScrolled = true;
      scrollToResult();
    };

    allFoodsWrapper.addEventListener('transitionend', scrollOnce, { once: true });
    window.setTimeout(scrollOnce, 350);
    collapseAllFoods();
  };

  const renderAllFoodPills = () => {
    if (!allFoodsPanel || allFoodsRendered) return;
    allFoodsPanel.innerHTML = searchIndex
      .map((item) => {
        const statusKey = normalizeStatus(item.status);
        const bgClass = STATUS_CLASS[statusKey];
        const emoji = getFoodEmoji(item);
        return `<button class="min-h-11 ${bgClass} text-on-background font-mono text-xs font-bold px-4 py-3 border-2 border-on-background shadow-hard-xs hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-hard-xxs transition-all rounded-sm btn-suggestion" data-food="${escapeHTML(item.name)}">${escapeHTML(item.name)} ${emoji}</button>`;
      })
      .join('');
    allFoodsRendered = true;

    // Delegate clicks for the newly-rendered pills (same behavior as the static suggestion chips)
    allFoodsPanel.querySelectorAll('.btn-suggestion').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const food = (e.currentTarget as HTMLButtonElement).getAttribute('data-food') || '';
        lookupInput.value = food;
        await loadSearchIndex();
        handleSearchEvent({ revealResult: true });
      });
    });
  };

  // Eager load / lazy fallback index loader
  const loadSearchIndex = (): Promise<void> => {
    if (indexPromise) return indexPromise;
    indexPromise = fetch('/api/alimentos.json')
      .then(res => {
        if (!res.ok) throw new Error('Error al descargar el índice de alimentos.');
        return res.json();
      })
      .then(data => {
        searchIndex = data as FoodEntry[];
        isIndexLoaded = true;
      })
      .catch(() => {
        isIndexLoaded = false;
        indexPromise = null; // Reset promise to allow retry
      });
    return indexPromise;
  };

  // We removed the eager global loadSearchIndex() call to optimize Lighthouse scores.

  const normalizeString = (str: string) => 
    str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

  const escapeHTML = (str: string) => 
    str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");

  const renderMarkdownItalics = (str: string) => 
    escapeHTML(str).replace(/\*(.*?)\*/g, "<i>$1</i>");

  const syncQueryParam = (rawQuery: string) => {
    const url = new URL(window.location.href);
    if (rawQuery.length >= 2) {
      url.searchParams.set('q', rawQuery);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
  };

  const handleSearchEvent = async ({ revealResult = false } = {}) => {
    const rawQuery = lookupInput.value.trim();
    const query = normalizeString(rawQuery);
    syncQueryParam(rawQuery);
    
    if (query.length < 2) {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackCopy.textContent = 'Escribe al menos dos letras y te contamos qué opinan tus lombrices 🪱.';
      retryButton.classList.add('hidden');
      return;
    }

    if (!isIndexLoaded) {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackCopy.textContent = 'Buscando en el diario de tus lombrices...';
      retryButton.classList.add('hidden');
    }

    await loadSearchIndex();
    if (!isIndexLoaded) {
      fallbackCopy.textContent = 'No pudimos cargar el buscador. Tu consulta sigue aquí para que puedas intentarlo de nuevo.';
      retryButton.classList.remove('hidden');
      return;
    }

    // Tiered search matching to prioritize names over keywords
    let filteredItem = searchIndex.find((item) => normalizeString(item.name) === query);
    
    if (!filteredItem) {
      filteredItem = searchIndex.find((item) => normalizeString(item.name).includes(query));
    }
    
    if (!filteredItem) {
      filteredItem = searchIndex.find((item) => normalizeString(item.category).includes(query));
    }
    
    if (!filteredItem) {
      filteredItem = searchIndex.find((item) => item.keywords && normalizeString(item.keywords).includes(query));
    }

    if (filteredItem) {
      fallbackMessage.classList.add('hidden');
      retryButton.classList.add('hidden');
      statusDisplay.classList.remove('hidden');

      // Safe DOM manipulation
      matchedFoodName.textContent = filteredItem.name;

      if (filteredItem.nutrition) {
        matchedNutritionContainer.classList.remove('hidden');
        matchedNutrition.textContent = `🌱 Perfil Nutricional: ${filteredItem.nutrition}`;
      } else {
        matchedNutritionContainer.classList.add('hidden');
      }

      matchedInstructions.innerHTML = renderMarkdownItalics(filteredItem.instructions);

      if (filteredItem.status === 'safe' || filteredItem.status === 'seguro') {
        statusDisplay.className = 'w-full border-4 border-on-background p-6 organic-brutalism bg-success-tint mt-6 box-border';
        badgeIndicator.className = 'font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-safe-badge text-on-background';
        badgeIndicator.textContent = 'SEGURO';
      } else if (filteredItem.status === 'warning' || filteredItem.status === 'moderacion') {
        statusDisplay.className = 'w-full border-4 border-on-background p-6 organic-brutalism bg-warning-tint mt-6 box-border';
        badgeIndicator.className = 'font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-warning-badge text-on-background';
        badgeIndicator.textContent = 'MODERACIÓN';
      } else if (filteredItem.status === 'danger' || filteredItem.status === 'peligro') {
        statusDisplay.className = 'w-full border-4 border-on-background p-6 organic-brutalism bg-danger-tint mt-6 box-border';
        badgeIndicator.className = 'font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-danger-badge text-white';
        badgeIndicator.textContent = 'PELIGRO';
      }

      if (revealResult) revealResultAfterFoodPick();
    } else {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackCopy.textContent = `No se registran datos sobre "${lookupInput.value}". Intenta con palabras clave como café, cítricos, cartón, cebolla o carne.`;
      retryButton.classList.add('hidden');
    }
  };

  retryButton.addEventListener('click', () => handleSearchEvent({ revealResult: true }));

  // Bind event listeners
  lookupInput.addEventListener('focus', () => loadSearchIndex());
  lookupInput.addEventListener('input', () => handleSearchEvent());

  // Prefetch index on mouse hover or touch start to speed up response
  lookupInput.addEventListener('pointerover', () => loadSearchIndex(), { once: true });
  lookupInput.addEventListener('touchstart', () => loadSearchIndex(), { once: true });

  const initialQuery = new URLSearchParams(window.location.search).get('q');
  if (initialQuery) {
    lookupInput.value = initialQuery;
    loadSearchIndex().then(() => {
      handleSearchEvent({ revealResult: true });
    });
  }

  // Suggestion buttons click handler
  suggestionButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const food = (e.currentTarget as HTMLButtonElement).getAttribute('data-food') || '';
      lookupInput.value = food;
      await loadSearchIndex();
      handleSearchEvent();
    });
    // Prefetch index on suggestion button hover/touch
    btn.addEventListener('pointerover', () => loadSearchIndex(), { once: true });
    btn.addEventListener('touchstart', () => loadSearchIndex(), { once: true });
  });

  // Expand/collapse the full food list
  if (toggleAllFoodsBtn && collapseAllFoodsBtn && allFoodsWrapper) {
    toggleAllFoodsBtn.addEventListener('click', async () => {
      await loadSearchIndex();
      renderAllFoodPills();
      allFoodsWrapper.style.gridTemplateRows = '1fr';
      toggleAllFoodsBtn.setAttribute('aria-expanded', 'true');
      toggleAllFoodsBtn.classList.add('hidden');
    });

    collapseAllFoodsBtn.addEventListener('click', collapseAllFoods);

    toggleAllFoodsBtn.addEventListener('pointerover', () => loadSearchIndex(), { once: true });
  }
</script>
