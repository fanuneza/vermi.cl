---
// IsItCompostable.astro - The "¿Le puedo echar esto?" Interactive Widget
---
<div class="relative w-full max-w-4xl bg-surface-container-high border-4 border-on-background organic-shape-3 p-6 md:p-12 shadow-hard my-8 z-10 box-border mx-auto">
  <div class="absolute -top-5 left-1/2 -translate-x-1/2 bg-surface text-on-background font-headline text-xl md:text-2xl px-6 py-2 border-4 border-on-background shadow-hard-sm rotate-[-2deg] font-black whitespace-nowrap uppercase">
    ¿Le puedo echar esto?
  </div>

  <div class="flex flex-col gap-6 mt-6">
    <div class="relative flex border-4 border-on-background rounded-full overflow-hidden bg-surface focus-within:ring-4 focus-within:ring-primary-container focus-within:border-primary transition-all">
      <!-- Inline SVG Search Icon to optimize Lighthouse scores -->
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-ink)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input
        type="text"
        id="food-lookup-input"
        placeholder="Ej: cáscara de plátano, café, cítricos..."
        class="w-full border-none bg-transparent py-4 pl-14 pr-4 font-headline text-xl text-on-background placeholder:text-outline focus:ring-0 focus:outline-none"
        autocomplete="off"
      />
    </div>

    <!-- Suggestion Tags -->
    <div class="flex flex-wrap justify-center gap-3 mt-4">
      <button class="bg-primary-container text-on-primary-container font-mono text-xs font-bold px-4 py-2 border-2 border-on-background shadow-[2px_2px_0px_0px_#002201] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#002201] transition-all rounded-sm rotate-1 btn-suggestion" data-food="plátano">Plátano 🍌</button>
      <button class="bg-error-container text-on-error-container font-mono text-xs font-bold px-4 py-2 border-2 border-on-background shadow-[2px_2px_0px_0px_#002201] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#002201] transition-all rounded-sm rotate-[-1deg] btn-suggestion" data-food="cítricos">Cítricos 🍊</button>
      <button class="bg-secondary-container text-on-secondary-container font-mono text-xs font-bold px-4 py-2 border-2 border-on-background shadow-[2px_2px_0px_0px_#002201] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#002201] transition-all rounded-sm rotate-2 btn-suggestion" data-food="cartón">Cartón 📦</button>
      <button class="bg-surface-variant text-on-surface-variant font-mono text-xs font-bold px-4 py-2 border-2 border-on-background shadow-[2px_2px_0px_0px_#002201] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[1px_1px_0px_0px_#002201] transition-all rounded-sm btn-suggestion" data-food="café">Borra de café ☕</button>
    </div>
  </div>

  <!-- Results Displays -->
  <div id="status-display-card" class="hidden w-full border-4 border-on-background p-6 shadow-hard-sm organic-brutalism bg-[#E8F8EE] mt-6 box-border">
    <div class="flex justify-between items-center border-b-2 border-on-background pb-3 mb-4">
      <span class="font-mono text-xs font-bold text-on-background tracking-wider">[ ANÁLISIS MICROBIOLÓGICO ]</span>
      <span id="badge-indicator" class="font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-safe-badge text-on-background">SEGURO</span>
    </div>
    <h3 id="matched-food-name" class="font-headline text-2xl md:text-3xl font-black text-on-background mb-3 uppercase">Cáscara de plátano</h3>
    
    <div class="border-l-4 border-secondary pl-3 mb-4 bg-black/5 py-1">
      <p id="matched-chilean-context" class="font-mono text-xs italic text-on-background m-0"></p>
    </div>
    
    <p id="matched-instructions" class="font-body text-base text-on-background leading-relaxed m-0"></p>
  </div>

  <div id="search-fallback-message" class="font-mono text-sm text-ink border-3 border-dashed border-on-background p-6 text-center bg-white/20 mt-6 rounded-lg box-border">
    Escribe al menos dos letras para iniciar la consulta microbiológica del residuo.
  </div>
</div>

<script>
  let searchIndex: any[] = [];
  let isIndexLoaded = false;

  const lookupInput = document.getElementById('food-lookup-input') as HTMLInputElement;
  const statusDisplay = document.getElementById('status-display-card') as HTMLDivElement;
  const fallbackMessage = document.getElementById('search-fallback-message') as HTMLDivElement;
  const badgeIndicator = document.getElementById('badge-indicator') as HTMLSpanElement;
  const matchedFoodName = document.getElementById('matched-food-name') as HTMLHeadingElement;
  const matchedChileanContext = document.getElementById('matched-chilean-context') as HTMLParagraphElement;
  const matchedInstructions = document.getElementById('matched-instructions') as HTMLParagraphElement;
  const suggestionButtons = document.querySelectorAll('.btn-suggestion');

  // Lazy-load the static JSON search index on first interaction
  const loadSearchIndex = async () => {
    if (isIndexLoaded) return;
    try {
      const response = await fetch('/api/alimentos.json');
      if (!response.ok) throw new Error('Error al descargar el índice de alimentos.');
      searchIndex = await response.json();
      isIndexLoaded = true;
    } catch (error) {
      console.error('Error de inicialización del buscador local:', error);
    }
  };

  const handleSearchEvent = () => {
    const rawQuery = lookupInput.value.toLowerCase().trim();
    
    if (rawQuery.length < 2) {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackMessage.textContent = 'Escribe al menos dos letras para iniciar la consulta microbiológica del residuo.';
      return;
    }

    if (!isIndexLoaded) return;

    // Fuzzy matching logic
    const filteredItem = searchIndex.find((item: any) =>
      item.name.toLowerCase().includes(rawQuery) ||
      item.category.toLowerCase().includes(rawQuery) ||
      (item.chileanContext && item.chileanContext.toLowerCase().includes(rawQuery))
    );

    if (filteredItem) {
      fallbackMessage.classList.add('hidden');
      statusDisplay.classList.remove('hidden');

      // Safe DOM manipulation to prevent XSS
      matchedFoodName.textContent = filteredItem.name;
      matchedChileanContext.textContent = `🇨🇱 Contexto Nacional: ${filteredItem.chileanContext || 'Información general.'}`;
      matchedInstructions.textContent = filteredItem.instructions;

      if (filteredItem.status === 'safe' || filteredItem.status === 'seguro') {
        statusDisplay.className = 'w-full border-4 border-on-background p-6 shadow-hard-sm organic-brutalism bg-[#E8F8EE] mt-6 box-border';
        badgeIndicator.className = 'font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-safe-badge text-on-background';
        badgeIndicator.textContent = 'SEGURO';
      } else if (filteredItem.status === 'warning' || filteredItem.status === 'moderacion') {
        statusDisplay.className = 'w-full border-4 border-on-background p-6 shadow-hard-sm organic-brutalism bg-[#FFFBEA] mt-6 box-border';
        badgeIndicator.className = 'font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-warning-badge text-on-background';
        badgeIndicator.textContent = 'MODERACIÓN';
      } else if (filteredItem.status === 'danger' || filteredItem.status === 'peligro') {
        statusDisplay.className = 'w-full border-4 border-on-background p-6 shadow-hard-sm organic-brutalism bg-[#FFF0F0] mt-6 box-border';
        badgeIndicator.className = 'font-mono text-sm font-bold border-2 border-on-background px-3 py-1 rounded-full bg-danger-badge text-white';
        badgeIndicator.textContent = 'PELIGRO';
      }
    } else {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackMessage.textContent = `No se registran datos sobre "${lookupInput.value}". Intenta con palabras clave como café, cítricos, cartón, cebolla o carne.`;
    }
  };

  // Bind event listeners
  lookupInput.addEventListener('focus', loadSearchIndex);
  lookupInput.addEventListener('input', handleSearchEvent);

  // Suggestion buttons click handler
  suggestionButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      await loadSearchIndex();
      const food = (e.currentTarget as HTMLButtonElement).getAttribute('data-food') || '';
      lookupInput.value = food;
      handleSearchEvent();
    });
  });
</script>
