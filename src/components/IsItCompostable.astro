---
// IsItCompostable.astro - The "¿Le puedo echar esto?" Interactive Widget
---
<div class="search-widget-container organic-shape-3 shadow-hard">
  <div class="widget-badge-title">
    ¿Le puedo echar esto?
  </div>

  <div class="widget-content">
    <div class="search-input-wrapper">
      <span class="search-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </span>
      <input
        type="text"
        id="food-lookup-input"
        placeholder="Ej: cáscara de plátano, café, cítricos..."
        class="search-input"
        autocomplete="off"
      />
    </div>

    <!-- Suggestion Tags -->
    <div class="suggestion-tags">
      <button class="btn-suggestion btn-sug-green rotate-1" data-food="café">Borra de café ☕</button>
      <button class="btn-suggestion btn-sug-red rotate-minus" data-food="cítricos">Cítricos 🍊</button>
      <button class="btn-suggestion btn-sug-orange rotate-2" data-food="cartón">Cartón 📦</button>
      <button class="btn-suggestion btn-sug-gray" data-food="cebolla">Cebolla 🧅</button>
    </div>
  </div>

  <!-- Results Displays -->
  <div id="status-display-card" class="hidden result-card organic-brutalism shadow-hard-sm">
    <div class="result-header">
      <span class="font-mono-tag">[ ANÁLISIS MICROBIOLÓGICO ]</span>
      <span id="badge-indicator" class="result-badge">SEGURO</span>
    </div>
    <h3 id="matched-food-name" class="result-food-name">Cáscara de Plátano</h3>
    
    <div class="chilean-context-wrapper">
      <p id="matched-chilean-context" class="result-chilean-context"></p>
    </div>
    
    <p id="matched-instructions" class="result-instructions"></p>
  </div>

  <div id="search-fallback-message" class="fallback-message">
    Escribe al menos dos letras para iniciar la consulta microbiológica del residuo.
  </div>
</div>

<style>
  .search-widget-container {
    position: relative;
    max-width: 900px;
    margin: 3rem auto;
    background-color: var(--color-surface-container-high);
    border: 4px solid var(--color-ink);
    padding: 2.5rem 1.5rem 1.5rem 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .search-widget-container {
      padding: 3.5rem 3rem 2.5rem 3rem;
      margin: 4rem auto;
    }
  }

  .widget-badge-title {
    position: absolute;
    top: -24px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    background-color: var(--color-bg-warm);
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    padding: 0.5rem 1.5rem;
    border: 4px solid var(--color-ink);
    box-shadow: 4px 4px 0px 0px var(--color-ink);
    white-space: nowrap;
    z-index: 20;
    text-transform: uppercase;
  }

  @media (min-width: 768px) {
    .widget-badge-title {
      font-size: 1.5rem;
    }
  }

  .widget-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .search-input {
    width: 100%;
    border: 4px solid var(--color-ink);
    border-radius: 9999px; /* rounded-full */
    padding: 1.25rem 1.5rem 1.25rem 3.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    background-color: var(--color-bg-warm);
    color: var(--color-ink);
    transition: all 0.15s cubic-bezier(0.16, 1, 0.3, 1);
    box-sizing: border-box;
  }
  .search-input:focus {
    outline: none;
    background-color: var(--color-white);
    box-shadow: 0px 0px 0px 4px var(--color-primary-container);
  }

  .search-icon {
    position: absolute;
    left: 1.25rem;
    color: var(--color-ink);
    pointer-events: none;
    display: flex;
    z-index: 10;
  }

  .suggestion-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .btn-suggestion {
    font-family: var(--font-mono);
    font-size: 0.825rem;
    font-weight: 700;
    padding: 0.5rem 1rem;
    border: 2px solid var(--color-ink);
    cursor: pointer;
    transition: all 0.1s ease;
    border-radius: 4px;
    box-shadow: 2px 2px 0px 0px var(--color-ink);
  }
  
  .btn-sug-green {
    background-color: var(--color-primary-container);
    color: var(--color-on-primary-container);
  }
  .btn-sug-red {
    background-color: var(--color-error-container);
    color: var(--color-on-error-container);
  }
  .btn-sug-orange {
    background-color: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
  }
  .btn-sug-gray {
    background-color: var(--color-surface-variant);
    color: var(--color-ink);
  }

  .btn-suggestion:hover {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px 0px var(--color-ink);
  }
  .btn-suggestion:active {
    transform: translate(2px, 2px);
    box-shadow: 0px 0px 0px 0px var(--color-ink);
  }

  /* Result styling classes */
  .result-card {
    border: 3px solid var(--color-ink);
    padding: 1.5rem;
    margin-top: 1.5rem;
    box-sizing: border-box;
  }

  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid var(--color-ink);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .result-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 900;
    border: 2px solid var(--color-ink);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px; /* rounded-pill */
  }

  .font-mono-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: 0.05em;
  }

  .result-food-name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 900;
    margin-bottom: 0.75rem;
    color: var(--color-ink);
    text-transform: uppercase;
  }

  .chilean-context-wrapper {
    border-left: 4px solid var(--color-secondary);
    padding-left: 0.75rem;
    margin-bottom: 1rem;
    background-color: rgba(0, 0, 0, 0.03);
    padding-top: 0.35rem;
    padding-bottom: 0.35rem;
  }

  .result-chilean-context {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-ink);
    margin: 0;
  }

  .result-instructions {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    line-height: 1.6;
    margin: 0;
  }

  .fallback-message {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-ink);
    border: 3px dashed var(--color-ink);
    padding: 1.5rem;
    text-align: center;
    background-color: rgba(255, 255, 255, 0.2);
    margin-top: 1.5rem;
    border-radius: 8px;
    box-sizing: border-box;
  }

  .rotate-1 { transform: rotate(1.5deg); }
  .rotate-minus { transform: rotate(-1.5deg); }
  .rotate-2 { transform: rotate(1deg); }

  .hidden {
    display: none !important;
  }
</style>

<script>
  let searchIndex: any[] = [];
  let isIndexLoaded = false;

  const lookupInput = document.getElementById('food-lookup-input') as HTMLInputElement;
  const statusDisplay = document.getElementById('status-display-card') as HTMLDivElement;
  const fallbackMessage = document.getElementById('search-fallback-message') as HTMLDivElement;
  const badgeIndicator = document.getElementById('badge-indicator') as HTMLSpanElement;
  const matchedFoodName = document.getElementById('matched-food-name') as HTMLHeadingElement;
  const matchedChileanContext = document.getElementById('matched-chilean-context') as HTMLParagraphElement;
  const matchedInstructions = document.getElementById('matched-instructions') as HTMLParagraphElement;
  const suggestionButtons = document.querySelectorAll('.btn-suggestion');

  // Lazy-load the static JSON search index on first interaction
  const loadSearchIndex = async () => {
    if (isIndexLoaded) return;
    try {
      const response = await fetch('/api/alimentos.json');
      if (!response.ok) throw new Error('Error al descargar el índice de alimentos.');
      searchIndex = await response.json();
      isIndexLoaded = true;
    } catch (error) {
      console.error('Error de inicialización del buscador local:', error);
    }
  };

  const handleSearchEvent = () => {
    const rawQuery = lookupInput.value.toLowerCase().trim();
    
    if (rawQuery.length < 2) {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackMessage.textContent = 'Escribe al menos dos letras para iniciar la consulta microbiológica del residuo.';
      return;
    }

    if (!isIndexLoaded) return;

    // Fuzzy matching logic
    const filteredItem = searchIndex.find((item: any) =>
      item.name.toLowerCase().includes(rawQuery) ||
      item.category.toLowerCase().includes(rawQuery) ||
      (item.chileanContext && item.chileanContext.toLowerCase().includes(rawQuery))
    );

    if (filteredItem) {
      fallbackMessage.classList.add('hidden');
      statusDisplay.classList.remove('hidden');

      // Safe DOM manipulation to prevent XSS
      matchedFoodName.textContent = filteredItem.name;
      matchedChileanContext.textContent = `🇨🇱 Contexto Nacional: ${filteredItem.chileanContext || 'Información general.'}`;
      matchedInstructions.textContent = filteredItem.instructions;
      
      // Map statuses to zine style colors
      badgeIndicator.textContent = filteredItem.status.toUpperCase();
      badgeIndicator.className = 'result-badge';

      if (filteredItem.status === 'safe' || filteredItem.status === 'seguro') {
        statusDisplay.className = 'result-card organic-brutalism shadow-hard-sm';
        statusDisplay.style.backgroundColor = '#E8F8EE'; // light green
        badgeIndicator.style.backgroundColor = 'var(--color-safe-badge)'; // #59C985
        badgeIndicator.style.color = 'var(--color-ink)';
        badgeIndicator.textContent = 'SEGURO';
      } else if (filteredItem.status === 'warning' || filteredItem.status === 'moderacion') {
        statusDisplay.className = 'result-card organic-brutalism shadow-hard-sm';
        statusDisplay.style.backgroundColor = '#FFFBEA'; // light yellow
        badgeIndicator.style.backgroundColor = 'var(--color-warning-badge)'; // #F0C842
        badgeIndicator.style.color = 'var(--color-ink)';
        badgeIndicator.textContent = 'MODERACIÓN';
      } else if (filteredItem.status === 'danger' || filteredItem.status === 'peligro') {
        statusDisplay.className = 'result-card organic-brutalism shadow-hard-sm';
        statusDisplay.style.backgroundColor = '#FFF0F0'; // light red
        badgeIndicator.style.backgroundColor = 'var(--color-danger-badge)'; // #E05353
        badgeIndicator.style.color = '#FFFFFF';
        badgeIndicator.textContent = 'PELIGRO';
      }
    } else {
      statusDisplay.classList.add('hidden');
      fallbackMessage.classList.remove('hidden');
      fallbackMessage.textContent = `No se registran datos sobre "${lookupInput.value}". Intenta con palabras clave como café, cítricos, cartón, cebolla o carne.`;
    }
  };

  // Bind event listeners
  lookupInput.addEventListener('focus', loadSearchIndex);
  lookupInput.addEventListener('input', handleSearchEvent);

  // Suggestion buttons click handler
  suggestionButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      await loadSearchIndex();
      const food = (e.currentTarget as HTMLButtonElement).getAttribute('data-food') || '';
      lookupInput.value = food;
      handleSearchEvent();
    });
  });
</script>
