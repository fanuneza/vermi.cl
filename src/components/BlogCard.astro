---
import { Image } from 'astro:assets';
import type { BlogTagSlug } from '../utils/blog-tags';
import {
  blogCardCategoryMeta,
  formatBlogDate,
  type BlogCategory,
} from '../utils/blog-presentation';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: BlogCategory;
  difficulty?: string;
  readingTime?: string;
  tags?: readonly BlogTagSlug[];
  rotation?: string; // e.g. "rotate-1" or "rotate-[-1.5deg]"
  heroImage?: any;
}

const { title, description, slug, pubDate, category, difficulty = "Básico", readingTime, rotation = "rotate-0", heroImage } = Astro.props;

const formattedDate = formatBlogDate(pubDate);
const meta = blogCardCategoryMeta[category];
---

<div class={`transition-transform duration-200 hover:scale-[1.02] ${rotation}`}>
  <article class={`border-4 border-on-background shadow-hard p-6 flex flex-col h-full min-h-[260px] transition-all hover:shadow-[8px_8px_0px_0px_#002201] organic-brutalism ${meta.bg}`}>
    <a href={`/blog/${slug}/`} class="block no-underline text-inherit">
      {heroImage && (
        <div class="w-full aspect-video mb-4 overflow-hidden border-4 border-on-background shadow-[4px_4px_0px_0px_#002201] organic-brutalism-alt bg-tertiary-fixed">
          <Image
            src={heroImage}
            alt={`Portada de ${title}`}
            class="w-full h-full object-cover"
            width={400}
            height={225}
            quality="mid"
          />
        </div>
      )}
      <div class="flex justify-between items-center mb-4 flex-wrap gap-2">
        <span class={`font-mono text-[10px] font-bold border-2 border-on-background px-2 py-0.5 shadow-[2px_2px_0px_0px_#002201] ${meta.tagBg} ${meta.tagText}`}>
          {meta.label}
        </span>
        <span class="font-mono text-xs font-bold text-on-background">{formattedDate}</span>
      </div>
      
      <h3 class="font-headline text-xl md:text-2xl font-black text-on-background mb-2 leading-tight uppercase line-clamp-2">
        {title}
      </h3>
      <p class="font-body text-sm text-on-background/90 mb-4 flex-grow line-clamp-3">
        {description}
      </p>
    </a>


      <div class="flex justify-between items-center border-t-2 border-dashed border-on-background pt-3 mt-auto">
        {readingTime && <span class="font-mono text-xs text-on-background/80">{readingTime}</span>}
        <span class="font-mono text-[10px] font-bold border-2 border-on-background px-2 py-0.5 bg-background text-on-background">
          {difficulty}
        </span>
      </div>
  </article>
</div>
