---
import { Picture } from 'astro:assets';
import type { BlogTagSlug } from '../utils/blog-tags';
import {
  blogCardImageSizes,
  blogCardImageWidths,
  blogCardCategoryMeta,
  formatBlogDate,
  type BlogCategory,
} from '../utils/blog-presentation';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: BlogCategory;
  difficulty?: string;
  readingTime?: string;
  tags?: readonly BlogTagSlug[];
  heroImage?: any;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "auto" | "low";
}

const {
  title,
  description,
  slug,
  pubDate,
  category,
  difficulty = "Básico",
  readingTime,
  heroImage,
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;

const formattedDate = formatBlogDate(pubDate);
const meta = blogCardCategoryMeta[category];
---

<article class={`quiet-card quiet-card-link zine-block zine-block--guide p-5 md:p-6 flex flex-col h-full min-h-[260px] ${meta.bg}`}>
    <a href={`/blog/${slug}/`} class="block no-underline text-inherit">
      {heroImage && (
        <div class="zine-block__image w-full aspect-video mb-5 overflow-hidden border-2 border-on-background organic-brutalism-alt bg-tertiary-fixed">
          <Picture
            src={heroImage}
            alt={`Portada de ${title}`}
            class="w-full h-full object-cover"
            formats={['avif']}
            fallbackFormat="webp"
            widths={[...blogCardImageWidths]}
            sizes={blogCardImageSizes}
            quality="mid"
            loading={loading}
            fetchpriority={fetchpriority}
          />
        </div>
      )}
      <div class="flex justify-between items-center mb-4 flex-wrap gap-2">
        <span class={`zine-block__category font-mono text-xs font-bold px-2 py-1 rounded-full ${meta.tagBg} ${meta.tagText}`}>
          {meta.label}
        </span>
        <span class="font-mono text-xs font-bold text-on-background">{formattedDate}</span>
      </div>
      
      <h3 class="font-headline text-xl md:text-2xl font-extrabold text-on-background mb-2 leading-tight line-clamp-2 text-balance">
        {title}
      </h3>
      <p class="font-body text-sm text-on-background/90 mb-4 flex-grow line-clamp-3">
        {description}
      </p>
    </a>


      <div class="zine-block__meta flex justify-between items-center border-t-2 border-dashed border-on-background pt-3 mt-auto">
        {readingTime && <span class="font-mono text-xs text-on-background/80">{readingTime}</span>}
        <span class="font-mono text-xs font-bold text-on-background/80">
          {difficulty}
        </span>
      </div>
</article>
