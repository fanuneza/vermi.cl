---
interface Props {
  href: string;
  title: string;
  description: string;
  badgeText: string;
  cardBgClass: string;
  textColorHoverClass: string;
  extraClasses?: string;
}

const {
  href,
  title,
  description,
  badgeText,
  cardBgClass,
  textColorHoverClass,
  extraClasses = "",
} = Astro.props;
---

<a class={`quiet-card quiet-card-link zine-block zine-block--portal block ${cardBgClass} p-6 group no-underline ${extraClasses}`} href={href}>
  <div class="zine-block__icon mb-4 inline-flex h-11 w-11 items-center justify-center text-primary">
    <slot name="icon" />
  </div>
  <h3 class={`font-headline text-2xl font-extrabold leading-tight text-on-surface mb-2 ${textColorHoverClass} transition-colors`}>{title}</h3>
  <p class="font-body text-base leading-relaxed text-on-surface-variant">{description}</p>
  <div class="mt-5 flex items-center justify-between gap-4 border-t border-on-surface/25 pt-4">
    <span class="font-mono text-xs font-bold text-on-surface-variant">{badgeText}</span>
    <span aria-hidden="true" class="text-primary font-bold">→</span>
  </div>
</a>
